---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import TagList from '../components/TagList.astro';
import {
	SITE_AUTHOR_NAME,
	SITE_BRAND_NAME,
	SITE_LANG,
	SITE_LOCALE,
	SITE_TITLE,
	SITE_URL,
} from '../consts';
import { getPostUrl } from '../utils/blog';

type BlogEntry = CollectionEntry<'blog'>;

interface Props extends BlogEntry['data'] {
	post: BlogEntry;
	previousPost?: BlogEntry | null;
	nextPost?: BlogEntry | null;
	relatedPosts?: BlogEntry[];
}

const {
	title,
	description,
	pubDate,
	updatedDate,
	heroImage,
	tags = [],
	post,
	previousPost = null,
	nextPost = null,
	relatedPosts = [],
} = Astro.props;
const postUrl = new URL(Astro.url.pathname, Astro.site).toString();
const imageUrl = heroImage ? new URL(heroImage.src, Astro.site).toString() : undefined;

const jsonLd = {
	'@context': 'https://schema.org',
	'@type': 'BlogPosting',
	headline: title,
	description,
	url: postUrl,
	datePublished: new Date(pubDate).toISOString(),
	dateModified: new Date(updatedDate ?? pubDate).toISOString(),
	mainEntityOfPage: postUrl,
	inLanguage: SITE_LOCALE.replace('_', '-'),
	image: imageUrl ? [imageUrl] : undefined,
	keywords: tags,
	articleSection: tags[0] ?? '블로그',
	author: {
		'@type': 'Organization',
		name: SITE_AUTHOR_NAME,
		url: SITE_URL,
	},
	publisher: {
		'@type': 'Organization',
		name: SITE_BRAND_NAME,
		url: SITE_URL,
	},
};

const breadcrumbJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{
			'@type': 'ListItem',
			position: 1,
			name: SITE_TITLE,
			item: SITE_URL,
		},
		{
			'@type': 'ListItem',
			position: 2,
			name: '블로그',
			item: `${SITE_URL}/blog/`,
		},
		{
			'@type': 'ListItem',
			position: 3,
			name: title,
			item: postUrl,
		},
	],
};
---

<html lang={SITE_LANG}>
	<head>
		<BaseHead title={title} description={description} keywords={tags} />
		<meta property="og:type" content="article" />
		<meta property="article:published_time" content={new Date(pubDate).toISOString()} />
		<meta property="article:modified_time" content={new Date(updatedDate ?? pubDate).toISOString()} />
		{tags.map((tag) => <meta property="article:tag" content={tag} />)}
		<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
		<script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
		<style>
			main {
				width: 100%;
				max-width: 100%;
				margin: 0;
				padding-left: 0;
				padding-right: 0;
			}
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
			}
			.prose {
				width: 100%;
				max-width: 780px;
				margin: 0 auto;
				padding: 1rem 1rem 0;
				color: rgb(var(--gray-dark));
			}
			.breadcrumbs {
				display: flex;
				flex-wrap: wrap;
				align-items: center;
				gap: 0.4rem;
				margin-bottom: 1rem;
				font-size: 0.85rem;
				color: rgb(var(--gray));
			}
			.breadcrumbs a {
				color: rgb(var(--gray-dark));
				text-decoration: none;
				font-weight: 500;
				transition: var(--transition-fast);
			}
			.breadcrumbs a:hover {
				color: var(--accent);
			}
			.title {
				margin-bottom: 1.5rem;
				padding: 1rem 0 0.5rem;
				line-height: 1.2;
			}
			.title h1 {
				margin: 0 0 0.75rem 0;
				font-size: clamp(2rem, 5vw, 3.2rem);
				line-height: 1.1;
				word-break: keep-all;
				letter-spacing: -0.035em;
			}
			.title .description {
				max-width: 620px;
				margin: 0.5rem 0 0;
				color: rgb(var(--gray));
				font-size: 1.05rem;
				line-height: 1.6;
			}
			.meta {
				display: flex;
				flex-wrap: wrap;
				gap: 0.75rem;
				align-items: center;
				margin-bottom: 0.85rem;
			}
			.date {
				color: rgb(var(--gray));
				font-size: 0.88rem;
			}
			.last-updated-on {
				font-style: italic;
			}
			.divider {
				border: none;
				border-top: 1px solid rgba(var(--line), 0.45);
				margin: 0;
			}
			.article-footer {
				margin-top: 3rem;
				padding-top: 1.5rem;
				border-top: 1px solid rgba(var(--line), 0.45);
				display: grid;
				gap: 1.5rem;
			}
			.section-title {
				margin-bottom: 0.75rem;
				font-size: 1.05rem;
				font-weight: 600;
			}
			.post-nav {
				display: grid;
				grid-template-columns: repeat(2, minmax(0, 1fr));
				gap: 1rem;
			}
			.post-nav a,
			.related-list a {
				display: block;
				text-decoration: none;
				color: inherit;
			}
			.post-nav-card,
			.related-card {
				padding: 1rem 1.15rem;
				border: 1px solid rgba(var(--line), 0.4);
				border-radius: 14px;
				background: #fff;
				transition: var(--transition-base);
			}
			.post-nav-card:hover,
			.related-card:hover {
				border-color: rgba(var(--line), 0.7);
				box-shadow: var(--shadow);
			}
			.post-nav-label {
				display: block;
				font-size: 0.75rem;
				font-weight: 700;
				letter-spacing: 0.06em;
				color: rgb(var(--gray));
				margin-bottom: 0.35rem;
				text-transform: uppercase;
			}
			.related-list {
				display: grid;
				grid-template-columns: repeat(2, minmax(0, 1fr));
				gap: 1rem;
			}
			.related-card h3,
			.post-nav-card h3 {
				margin: 0.2rem 0 0.3rem;
				font-size: 1rem;
				font-weight: 600;
			}
			.related-card p,
			.post-nav-card p {
				margin: 0;
				font-size: 0.9rem;
				color: rgb(var(--gray));
			}
			.related-meta {
				font-size: 0.82rem;
				color: rgb(var(--gray));
				margin-bottom: 0.3rem;
			}
			@media (max-width: 900px) {
				.related-list {
					grid-template-columns: 1fr;
				}
			}
			@media (max-width: 720px) {
				main {
					width: 100%;
					max-width: 100%;
					margin: 0;
					padding: 0;
				}
				.prose {
					width: 100%;
					max-width: 100%;
					margin: 0;
					padding: 0.65rem 0.75rem;
				}
				.title {
					padding: 0.35rem 0 0;
				}
				.title h1 {
					font-size: 1.8rem;
				}
				.post-nav {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <Image width={1200} height={630} src={heroImage} alt={title} />}
				</div>
				<div class="prose">
					<nav class="breadcrumbs" aria-label="breadcrumb">
						<a href="/">홈</a>
						<span>/</span>
						<a href="/blog/">블로그</a>
						<span>/</span>
						<span aria-current="page">{title}</span>
					</nav>
					<header class="title">
						<div class="meta">
							<div class="date">
								<FormattedDate date={pubDate} />
								{
									updatedDate && (
										<div class="last-updated-on">
											최종 수정 <FormattedDate date={updatedDate} />
										</div>
									)
								}
							</div>
							<TagList tags={tags} />
						</div>
						<h1>{title}</h1>
						<p class="description">{description}</p>
						<hr class="divider" />
					</header>
					<slot />

					<footer class="article-footer">
						{(previousPost || nextPost) && (
							<section aria-labelledby="post-navigation-title">
								<h2 id="post-navigation-title" class="section-title">이전/다음 글</h2>
								<div class="post-nav">
									{previousPost ? (
										<a href={getPostUrl(previousPost)}>
											<div class="post-nav-card">
												<span class="post-nav-label">더 최신 글</span>
												<h3>{previousPost.data.title}</h3>
												<p>{previousPost.data.description}</p>
											</div>
										</a>
									) : <div />}
									{nextPost ? (
										<a href={getPostUrl(nextPost)}>
											<div class="post-nav-card">
												<span class="post-nav-label">더 이전 글</span>
												<h3>{nextPost.data.title}</h3>
												<p>{nextPost.data.description}</p>
											</div>
										</a>
									) : <div />}
								</div>
							</section>
						)}

						{relatedPosts.length > 0 && (
							<section aria-labelledby="related-posts-title">
								<h2 id="related-posts-title" class="section-title">관련 글</h2>
								<div class="related-list">
									{relatedPosts.map((relatedPost) => (
										<a href={getPostUrl(relatedPost)}>
											<div class="related-card">
												<p class="related-meta"><FormattedDate date={relatedPost.data.pubDate} /></p>
												<h3>{relatedPost.data.title}</h3>
												<p>{relatedPost.data.description}</p>
												<div style="margin-top: 0.6rem;">
													<TagList tags={relatedPost.data.tags} />
												</div>
											</div>
										</a>
									))}
								</div>
							</section>
						)}
					</footer>
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
