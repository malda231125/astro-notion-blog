---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
// import Header from '../components/Header.astro';
import { SITE_TITLE, SITE_URL } from '../consts';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
const postUrl = new URL(Astro.url.pathname, Astro.site).toString();
const imageUrl = heroImage ? new URL(heroImage.src, Astro.site).toString() : undefined;
const jsonLd = {
	'@context': 'https://schema.org',
	'@type': 'BlogPosting',
	headline: title,
	description,
	datePublished: pubDate,
	dateModified: updatedDate ?? pubDate,
	mainEntityOfPage: postUrl,
	image: imageUrl,
	publisher: {
		'@type': 'Organization',
		name: SITE_TITLE,
		url: SITE_URL,
	},
};
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<meta property="og:type" content="article" />
		<meta property="article:published_time" content={new Date(pubDate).toISOString()} />
		<meta property="article:modified_time" content={new Date(updatedDate ?? pubDate).toISOString()} />
		<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
		<style>
			main {
				width: 100%;
				max-width: 100%;
				margin: 0;
				padding-left: 0;
				padding-right: 0;
			}
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.prose {
				width: 100%;
				max-width: 760px;
				margin: 0 auto;
				padding: 0.75rem 0.8rem;
				color: rgb(var(--gray-dark));
			}
			.title {
				margin-bottom: 1em;
				padding: 0.7em 0;
				text-align: center;
				line-height: 1.2;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
				font-size: clamp(1.9rem, 5.5vw, 3rem);
				line-height: 1.2;
				word-break: keep-all;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
				font-size: 0.95rem;
			}
			.last-updated-on {
				font-style: italic;
			}
			@media (max-width: 720px) {
				main {
					width: 100%;
					max-width: 100%;
					margin: 0;
					padding: 0;
				}
				.prose {
					width: 100%;
					max-width: 100%;
					margin: 0;
					padding: 0.65rem 0.75rem;
				}
				.title {
					padding: 0.35rem 0;
				}
				.title h1 {
					font-size: 2rem;
				}
			}
		</style>
	</head>

	<body>
		{/* <Header /> */}
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <Image width={1020} height={510} src={heroImage} alt="" />}
				</div>
				<div class="prose">
					<div class="title">
						<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										Last updated on <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<h1>{title}</h1>
						<hr />
					</div>
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
