---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';
import { getPostSlug, getRelatedPosts, sortBlogPosts } from '../../utils/blog';

export async function getStaticPaths() {
	const posts = sortBlogPosts(await getCollection('blog'));

	return posts.map((post, index) => ({
		params: { slug: getPostSlug(post) },
		props: {
			post,
			previousPost: posts[index - 1] ?? null,
			nextPost: posts[index + 1] ?? null,
			relatedPosts: getRelatedPosts(posts, post, 3),
		},
	}));
}

interface Props {
	post: CollectionEntry<'blog'>;
	previousPost: CollectionEntry<'blog'> | null;
	nextPost: CollectionEntry<'blog'> | null;
	relatedPosts: CollectionEntry<'blog'>[];
}

const { post, previousPost, nextPost, relatedPosts } = Astro.props;
const { Content } = await render(post);
---

<BlogPost
	{...post.data}
	post={post}
	previousPost={previousPost}
	nextPost={nextPost}
	relatedPosts={relatedPosts}
>
	<Content />
</BlogPost>
