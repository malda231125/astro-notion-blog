---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';
import TagList from '../../components/TagList.astro';
import PageLayout from '../../layouts/PageLayout.astro';
import { SITE_SECTION_DESCRIPTION, SITE_TITLE, SITE_URL } from '../../consts';
import { getPostUrl, sortBlogPosts } from '../../utils/blog';

const posts = sortBlogPosts(await getCollection('blog'));

const structuredData = [
	{
		'@context': 'https://schema.org',
		'@type': 'CollectionPage',
		name: `${SITE_TITLE} 글 모음`,
		description: 'OpenClaw와 AI 에이전트 운영, 자동화, 배포, 홈서버 관련 글 전체 목록입니다.',
		url: `${SITE_URL}/blog/`,
		inLanguage: 'ko-KR',
	},
	{
		'@context': 'https://schema.org',
		'@type': 'ItemList',
		itemListElement: posts.map((post, index) => ({
			'@type': 'ListItem',
			position: index + 1,
			url: `${SITE_URL}${getPostUrl(post)}`,
			name: post.data.title,
		})),
	},
];
---

<PageLayout
	title="블로그 아카이브"
	description="OpenClaw와 AI 에이전트 운영, 자동화, 배포, 홈서버 관련 글 전체 목록입니다."
	keywords={['블로그', 'OpenClaw', 'AI 에이전트', '자동화']}
	structuredData={structuredData}
>
	<section class="archive-hero">
		<p class="eyebrow">BLOG ARCHIVE</p>
		<h1>{SITE_TITLE} 글 모음</h1>
		<p class="lead">{SITE_SECTION_DESCRIPTION}</p>
	</section>

	<section class="archive-list" aria-labelledby="archive-list-title">
		<div class="section-heading">
			<h2 id="archive-list-title">전체 글</h2>
			<p>{posts.length}개의 글이 발행되어 있습니다.</p>
		</div>

		<div class="grid">
			{posts.map((post) => (
				<article class="card">
					<a href={getPostUrl(post)}>
						{post.data.heroImage && (
							<Image width={720} height={360} src={post.data.heroImage} alt={post.data.title} />
						)}
						<p class="meta">
							<FormattedDate date={post.data.pubDate} />
						</p>
						<h3>{post.data.title}</h3>
						<p class="desc">{post.data.description}</p>
					</a>
					<TagList tags={post.data.tags} />
				</article>
			))}
		</div>
	</section>
</PageLayout>

<style>
	.archive-hero {
		display: grid;
		gap: 0.75rem;
		padding: 0.5rem 0 1.75rem;
	}

	.eyebrow {
		margin: 0;
		font-size: 0.78rem;
		font-weight: 800;
		letter-spacing: 0.16em;
		color: var(--accent);
		text-transform: uppercase;
	}

	.lead,
	.section-heading p {
		margin: 0;
		color: rgb(var(--gray));
		font-size: 0.95rem;
	}

	.archive-list {
		margin-top: 0.5rem;
	}

	.section-heading {
		margin-bottom: 1.15rem;
	}

	.section-heading h2 {
		font-size: clamp(1.5rem, 3vw, 2rem);
	}

	.grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
	}

	.card {
		display: grid;
		gap: 0.65rem;
		padding: 1.15rem;
		border: 1px solid rgba(var(--line), 0.25);
		border-radius: var(--radius-lg, 22px);
		background: rgba(255, 255, 255, 0.7);
		box-shadow: var(--shadow-sm, 0 1px 3px rgba(0,0,0,0.06));
		transition: box-shadow 200ms ease, transform 200ms ease;
	}

	.card:hover {
		box-shadow: var(--shadow, 0 8px 24px rgba(0,0,0,0.08));
		transform: translateY(-2px);
	}

	.card a {
		text-decoration: none;
		color: inherit;
	}

	.card img {
		width: 100%;
		height: auto;
		border-radius: var(--radius-md, 14px);
	}

	.card h3 {
		margin: 0.15rem 0 0.3rem;
		font-size: 1.15rem;
		line-height: 1.35;
		transition: color 150ms ease;
	}

	.card:hover h3 {
		color: var(--accent);
	}

	.card .desc {
		margin: 0;
		font-size: 0.92rem;
		color: rgb(var(--gray));
		line-height: 1.55;
	}

	.card p {
		margin: 0;
	}

	.meta {
		font-size: 0.88rem;
		color: rgb(var(--gray));
	}

	@media (max-width: 900px) {
		.grid {
			grid-template-columns: 1fr;
		}
	}
</style>
