---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';
import TagList from '../../components/TagList.astro';
import PageLayout from '../../layouts/PageLayout.astro';
import { SITE_SECTION_DESCRIPTION, SITE_TITLE, SITE_URL } from '../../consts';
import { getPostUrl, sortBlogPosts } from '../../utils/blog';

const posts = sortBlogPosts(await getCollection('blog'));

const structuredData = [
	{
		'@context': 'https://schema.org',
		'@type': 'CollectionPage',
		name: `${SITE_TITLE} 글 모음`,
		description: 'OpenClaw와 AI 에이전트 운영, 자동화, 배포, 홈서버 관련 글 전체 목록입니다.',
		url: `${SITE_URL}/blog/`,
		inLanguage: 'ko-KR',
	},
	{
		'@context': 'https://schema.org',
		'@type': 'ItemList',
		itemListElement: posts.map((post, index) => ({
			'@type': 'ListItem',
			position: index + 1,
			url: `${SITE_URL}${getPostUrl(post)}`,
			name: post.data.title,
		})),
	},
];
---

<PageLayout
	title="블로그 아카이브"
	description="OpenClaw와 AI 에이전트 운영, 자동화, 배포, 홈서버 관련 글 전체 목록입니다."
	keywords={['블로그', 'OpenClaw', 'AI 에이전트', '자동화']}
	structuredData={structuredData}
>
	<section class="archive-hero">
		<p class="eyebrow">BLOG ARCHIVE</p>
		<h1>{SITE_TITLE} 글 모음</h1>
		<p class="lead">{SITE_SECTION_DESCRIPTION}</p>
		<p class="post-count">{posts.length}개의 글이 발행되어 있습니다.</p>
	</section>

	<section class="archive-list" aria-labelledby="archive-list-title">
		<h2 id="archive-list-title" class="sr-only">전체 글 목록</h2>

		<div class="grid">
			{posts.map((post, i) => (
				<article class="card" style={`animation-delay: ${i * 40}ms`}>
					<a href={getPostUrl(post)}>
						{post.data.heroImage && (
							<div class="card-image">
								<Image width={720} height={360} src={post.data.heroImage} alt={post.data.title} />
							</div>
						)}
						<div class="card-body">
							<p class="meta">
								<FormattedDate date={post.data.pubDate} />
							</p>
							<h3>{post.data.title}</h3>
							<p class="card-desc">{post.data.description}</p>
						</div>
					</a>
					<div class="card-footer">
						<TagList tags={post.data.tags} />
					</div>
				</article>
			))}
		</div>
	</section>
</PageLayout>

<style>
	.archive-hero {
		display: grid;
		gap: 0.75rem;
		padding: var(--space-md) 0 var(--space-xl);
	}

	.eyebrow {
		margin: 0;
		font-size: 0.78rem;
		font-weight: 800;
		letter-spacing: 0.14em;
		color: var(--accent);
	}

	.archive-hero h1 {
		margin: 0;
	}

	.lead {
		margin: 0;
		color: rgb(var(--gray));
		max-width: 62ch;
		line-height: 1.65;
	}

	.post-count {
		margin: 0;
		font-size: 0.92rem;
		color: rgb(var(--gray));
		font-weight: 600;
	}

	.archive-list {
		margin-top: 0;
	}

	.grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: var(--space-md);
	}

	.card {
		display: flex;
		flex-direction: column;
		border: 1px solid rgba(var(--line), 0.3);
		border-radius: var(--radius-lg);
		background: rgba(255, 255, 255, 0.72);
		box-shadow: var(--shadow-sm);
		backdrop-filter: blur(10px);
		-webkit-backdrop-filter: blur(10px);
		overflow: hidden;
		transition: box-shadow var(--duration-base) var(--ease-out),
			transform var(--duration-base) var(--ease-out),
			border-color var(--duration-base) var(--ease-out);
	}

	.card:hover {
		box-shadow: var(--shadow);
		transform: translateY(-3px);
		border-color: rgba(var(--accent-rgb), 0.15);
	}

	.card a {
		text-decoration: none;
		color: inherit;
		flex: 1;
	}

	.card-image {
		overflow: hidden;
	}

	.card-image img {
		width: 100%;
		height: auto;
		display: block;
		border-radius: 0;
		transition: transform var(--duration-slow) var(--ease-out);
	}

	.card:hover .card-image img {
		transform: scale(1.03);
	}

	.card-body {
		padding: var(--space-md);
	}

	.card h3 {
		margin: 0.15rem 0 0.4rem;
		font-size: 1.15rem;
		transition: color var(--duration-fast) var(--ease-out);
	}

	.card:hover h3 {
		color: var(--accent);
	}

	.card-desc {
		margin: 0;
		color: rgb(var(--gray));
		font-size: 0.94rem;
		line-height: 1.55;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.card-footer {
		padding: 0 var(--space-md) var(--space-md);
	}

	.meta {
		font-size: 0.88rem;
		color: rgb(var(--gray));
		margin: 0 0 0.15rem;
	}

	@media (max-width: 900px) {
		.grid {
			grid-template-columns: 1fr;
		}
	}
</style>
