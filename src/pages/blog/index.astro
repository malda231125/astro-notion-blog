---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';
import TagList from '../../components/TagList.astro';
import PageLayout from '../../layouts/PageLayout.astro';
import { SITE_SECTION_DESCRIPTION, SITE_TITLE, SITE_URL } from '../../consts';
import { getPostUrl, sortBlogPosts } from '../../utils/blog';

const posts = sortBlogPosts(await getCollection('blog'));

const structuredData = [
	{
		'@context': 'https://schema.org',
		'@type': 'CollectionPage',
		name: `${SITE_TITLE} 글 모음`,
		description: 'OpenClaw와 AI 에이전트 운영, 자동화, 배포, 홈서버 관련 글 전체 목록입니다.',
		url: `${SITE_URL}/blog/`,
		inLanguage: 'ko-KR',
	},
	{
		'@context': 'https://schema.org',
		'@type': 'ItemList',
		itemListElement: posts.map((post, index) => ({
			'@type': 'ListItem',
			position: index + 1,
			url: `${SITE_URL}${getPostUrl(post)}`,
			name: post.data.title,
		})),
	},
];
---

<PageLayout
	title="블로그 아카이브"
	description="OpenClaw와 AI 에이전트 운영, 자동화, 배포, 홈서버 관련 글 전체 목록입니다."
	keywords={['블로그', 'OpenClaw', 'AI 에이전트', '자동화']}
	structuredData={structuredData}
>
	<section class="archive-hero">
		<p class="eyebrow">BLOG ARCHIVE</p>
		<h1>{SITE_TITLE} 글 모음</h1>
		<p class="lead">{SITE_SECTION_DESCRIPTION}</p>
	</section>

	<section class="archive-list" aria-labelledby="archive-list-title">
		<div class="section-heading">
			<h2 id="archive-list-title">전체 글</h2>
			<p>{posts.length}개의 글이 발행되어 있습니다.</p>
		</div>

		<div class="grid stagger-in">
			{posts.map((post) => (
				<article class="post-item">
					<a href={getPostUrl(post)}>
						{post.data.heroImage && (
							<div class="post-thumb">
								<Image width={480} height={240} src={post.data.heroImage} alt={post.data.title} />
							</div>
						)}
						<div class="post-body">
							<p class="meta">
								<FormattedDate date={post.data.pubDate} />
							</p>
							<h3>{post.data.title}</h3>
							<p class="desc">{post.data.description}</p>
						</div>
					</a>
					<div class="post-tags">
						<TagList tags={post.data.tags} />
					</div>
				</article>
			))}
		</div>
	</section>
</PageLayout>

<style>
	.archive-hero {
		display: grid;
		gap: 0.75rem;
		padding: 0.5rem 0 1.5rem;
	}

	.eyebrow {
		margin: 0;
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.18em;
		color: var(--accent);
	}

	h1 {
		max-width: 20ch;
	}

	.lead,
	.section-heading p {
		margin: 0;
		color: rgb(var(--gray));
		font-size: 0.95rem;
	}

	.archive-list {
		margin-top: 0.5rem;
	}

	.section-heading {
		margin-bottom: 1.25rem;
	}

	.section-heading h2 {
		margin-bottom: 0.25rem;
	}

	/* 2-column asymmetric grid */
	.grid {
		display: grid;
		grid-template-columns: 1.2fr 1fr;
		gap: 1rem;
	}

	.post-item {
		border: 1px solid rgba(var(--line), 0.4);
		border-radius: 14px;
		background: #fff;
		overflow: hidden;
		transition: var(--transition-base);
	}

	.post-item:hover {
		border-color: rgba(var(--line), 0.7);
		box-shadow: var(--shadow);
	}

	.post-item a {
		text-decoration: none;
		color: inherit;
	}

	.post-thumb img {
		width: 100%;
		height: auto;
		display: block;
		border-radius: 0;
	}

	.post-body {
		padding: 1rem 1.15rem 0.5rem;
	}

	.post-tags {
		padding: 0 1.15rem 1rem;
	}

	.post-item h3 {
		margin: 0.15rem 0 0.35rem;
		font-size: 1.1rem;
		font-weight: 600;
	}

	.post-item p {
		margin: 0;
	}

	.desc {
		color: rgb(var(--gray));
		font-size: 0.9rem;
		line-height: 1.55;
	}

	.meta {
		font-size: 0.82rem;
		color: rgb(var(--gray));
	}

	@media (max-width: 900px) {
		.grid {
			grid-template-columns: 1fr;
		}
	}
</style>
