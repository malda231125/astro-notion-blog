---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';
import TagList from '../../components/TagList.astro';
import PageLayout from '../../layouts/PageLayout.astro';
import { SITE_SECTION_DESCRIPTION, SITE_TITLE, SITE_URL } from '../../consts';
import { getPostUrl, sortBlogPosts } from '../../utils/blog';

const posts = sortBlogPosts(await getCollection('blog'));

const structuredData = [
	{
		'@context': 'https://schema.org',
		'@type': 'CollectionPage',
		name: `${SITE_TITLE} 글 모음`,
		description: 'OpenClaw와 AI 에이전트 운영, 자동화, 배포, 홈서버 관련 글 전체 목록입니다.',
		url: `${SITE_URL}/blog/`,
		inLanguage: 'ko-KR',
	},
	{
		'@context': 'https://schema.org',
		'@type': 'ItemList',
		itemListElement: posts.map((post, index) => ({
			'@type': 'ListItem',
			position: index + 1,
			url: `${SITE_URL}${getPostUrl(post)}`,
			name: post.data.title,
		})),
	},
];
---

<PageLayout
	title="블로그 아카이브"
	description="OpenClaw와 AI 에이전트 운영, 자동화, 배포, 홈서버 관련 글 전체 목록입니다."
	keywords={['블로그', 'OpenClaw', 'AI 에이전트', '자동화']}
	structuredData={structuredData}
>
	<section class="archive-hero">
		<div class="archive-badge">BLOG ARCHIVE</div>
		<h1>{SITE_TITLE} 글 모음</h1>
		<p class="lead">{SITE_SECTION_DESCRIPTION}</p>
	</section>

	<section class="archive-list" aria-labelledby="archive-list-title">
		<div class="section-heading">
			<h2 id="archive-list-title">전체 글</h2>
			<p>{posts.length}개의 글이 발행되어 있습니다.</p>
		</div>

		<div class="grid">
			{posts.map((post, i) => (
				<article class="card" style={`animation-delay: ${i * 60}ms`}>
					<a href={getPostUrl(post)}>
						{post.data.heroImage && (
							<div class="card-image">
								<Image width={720} height={360} src={post.data.heroImage} alt={post.data.title} />
							</div>
						)}
						<div class="card-body">
							<p class="meta">
								<FormattedDate date={post.data.pubDate} />
							</p>
							<h3>{post.data.title}</h3>
							<p class="card-desc">{post.data.description}</p>
						</div>
					</a>
					<div class="card-footer">
						<TagList tags={post.data.tags} />
					</div>
				</article>
			))}
		</div>
	</section>
</PageLayout>

<style>
	.archive-hero {
		display: grid;
		gap: 0.85rem;
		padding: 1.5rem 0 2rem;
	}

	.archive-badge {
		display: inline-flex;
		align-items: center;
		padding: 0.35rem 0.75rem;
		border-radius: 999px;
		background: rgba(99, 102, 241, 0.08);
		border: 1px solid rgba(99, 102, 241, 0.15);
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		color: var(--accent);
		width: fit-content;
	}

	.lead,
	.section-heading p {
		margin: 0;
		color: rgb(var(--gray));
		font-size: 0.95rem;
	}

	.archive-list {
		margin-top: 0.5rem;
	}

	.section-heading {
		margin-bottom: 1.25rem;
	}

	.section-heading h2 {
		margin-bottom: 0.25rem;
	}

	.grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1.15rem;
	}

	.card {
		display: flex;
		flex-direction: column;
		border: 1px solid rgba(var(--line), 0.35);
		border-radius: 16px;
		background: rgba(255, 255, 255, 0.8);
		box-shadow: var(--shadow);
		overflow: hidden;
		transition: box-shadow var(--transition-normal), transform var(--transition-normal), border-color var(--transition-normal);
		animation: fadeInUp 0.5s var(--ease-out) both;
	}

	.card:hover {
		box-shadow: var(--shadow-lg);
		transform: translateY(-3px);
		border-color: rgba(99, 102, 241, 0.2);
	}

	.card a {
		text-decoration: none;
		color: inherit;
	}

	.card-image {
		overflow: hidden;
	}

	.card-image img {
		width: 100%;
		height: auto;
		border-radius: 0;
		transition: transform 0.5s var(--ease-out);
	}

	.card:hover .card-image img {
		transform: scale(1.03);
	}

	.card-body {
		padding: 1rem 1.15rem 0.5rem;
	}

	.card h3 {
		margin: 0.2rem 0 0.4rem;
		font-size: 1.1rem;
		line-height: 1.35;
		transition: color var(--transition-fast);
	}

	.card:hover h3 {
		color: var(--accent);
	}

	.card-desc {
		margin: 0;
		font-size: 0.92rem;
		color: rgb(var(--gray));
		line-height: 1.55;
	}

	.card-footer {
		padding: 0.65rem 1.15rem 1rem;
		margin-top: auto;
	}

	.meta {
		font-size: 0.85rem;
		color: rgb(var(--gray));
	}

	@media (max-width: 900px) {
		.grid {
			grid-template-columns: 1fr;
		}
	}
</style>
