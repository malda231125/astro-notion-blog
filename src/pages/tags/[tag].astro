---
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';
import TagList from '../../components/TagList.astro';
import PageLayout from '../../layouts/PageLayout.astro';
import { SITE_URL } from '../../consts';
import { getPostUrl, getTagSlug, isUsableTag, tagMatchesSlug } from '../../utils/blog';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	const tags = [
		...new Set(posts.flatMap((post) => (post.data.tags ?? []).filter((tag) => isUsableTag(tag)))),
	];
	return tags.map((tag) => ({
		params: { tag: getTagSlug(tag) },
		props: {
			tag,
			posts: posts.filter((post) => (post.data.tags ?? []).some((item) => item === tag)),
		},
	}));
}

const { tag, posts } = Astro.props;
const safeTag = typeof Astro.params.tag === 'string' ? Astro.params.tag : '';
const filteredPosts =
	posts?.filter((post) => (post.data.tags ?? []).some((item) => tagMatchesSlug(item, safeTag))) ?? [];
const structuredData = [
	{
		'@context': 'https://schema.org',
		'@type': 'CollectionPage',
		name: `태그: ${tag}`,
		description: `${tag} 태그로 분류된 글 모음입니다.`,
		url: `${SITE_URL}/tags/${safeTag}/`,
		inLanguage: 'ko-KR',
	},
	{
		'@context': 'https://schema.org',
		'@type': 'ItemList',
		itemListElement: filteredPosts.map((post, index) => ({
			'@type': 'ListItem',
			position: index + 1,
			url: `${SITE_URL}${getPostUrl(post)}`,
			name: post.data.title,
		})),
	},
];
---

<PageLayout
	title={`태그: ${tag}`}
	description={`${tag} 태그로 분류된 글 모음입니다.`}
	keywords={[tag, '태그', 'OpenClaw']}
	structuredData={structuredData}
>
	<section class="tag-page">
		<div class="tag-header">
			<p class="eyebrow">TAG ARCHIVE</p>
			<h1>#{tag}</h1>
			<p class="lead">이 태그와 관련된 글 {filteredPosts.length}개를 모았습니다.</p>
		</div>

		<div class="post-list">
			{filteredPosts.map((post, i) => (
				<article class="card" style={`animation-delay: ${i * 40}ms`}>
					<a href={getPostUrl(post)}>
						<p class="meta">
							<FormattedDate date={post.data.pubDate} />
						</p>
						<h2>{post.data.title}</h2>
						<p class="card-desc">{post.data.description}</p>
					</a>
					<TagList tags={post.data.tags} />
				</article>
			))}
		</div>

		<nav class="back-link" aria-label="태그 목록으로 돌아가기">
			<a href="/tags">
				<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>
				모든 태그 보기
			</a>
		</nav>
	</section>
</PageLayout>

<style>
	.tag-page {
		display: grid;
		gap: var(--space-xl);
	}

	.tag-header {
		display: grid;
		gap: 0.75rem;
	}

	.eyebrow {
		margin: 0;
		font-size: 0.78rem;
		font-weight: 800;
		letter-spacing: 0.14em;
		color: var(--accent);
	}

	.tag-header h1 {
		margin: 0;
	}

	.lead {
		margin: 0;
		color: rgb(var(--gray));
		line-height: 1.65;
	}

	.post-list {
		display: grid;
		gap: var(--space-md);
	}

	.card {
		display: grid;
		gap: 0.7rem;
		padding: var(--space-lg);
		border: 1px solid rgba(var(--line), 0.35);
		border-radius: var(--radius-lg);
		background: rgba(255, 255, 255, 0.72);
		box-shadow: var(--shadow-sm);
		backdrop-filter: blur(10px);
		-webkit-backdrop-filter: blur(10px);
		transition: box-shadow var(--duration-base) var(--ease-out),
			transform var(--duration-base) var(--ease-out),
			border-color var(--duration-base) var(--ease-out);
	}

	.card:hover {
		box-shadow: var(--shadow);
		transform: translateY(-2px);
		border-color: rgba(var(--accent-rgb), 0.15);
	}

	.card a {
		text-decoration: none;
		color: inherit;
	}

	.card h2 {
		margin: 0.1rem 0 0.35rem;
		font-size: 1.35rem;
		transition: color var(--duration-fast) var(--ease-out);
	}

	.card:hover h2 {
		color: var(--accent);
	}

	.card-desc {
		margin: 0;
		color: rgb(var(--gray));
		font-size: 0.95rem;
		line-height: 1.6;
	}

	.meta {
		font-size: 0.88rem;
		color: rgb(var(--gray));
		margin: 0;
	}

	.back-link {
		padding-top: var(--space-md);
	}

	.back-link a {
		display: inline-flex;
		align-items: center;
		gap: 0.3rem;
		font-weight: 600;
		font-size: 0.95rem;
		text-decoration: none;
		color: var(--accent);
		transition: gap var(--duration-fast) var(--ease-out);
	}

	.back-link a:hover {
		gap: 0.5rem;
	}
</style>
