---
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';
import TagList from '../../components/TagList.astro';
import PageLayout from '../../layouts/PageLayout.astro';
import { SITE_URL } from '../../consts';
import { getPostUrl, getTagSlug, isUsableTag, tagMatchesSlug } from '../../utils/blog';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	const tags = [
		...new Set(posts.flatMap((post) => (post.data.tags ?? []).filter((tag) => isUsableTag(tag)))),
	];
	return tags.map((tag) => ({
		params: { tag: getTagSlug(tag) },
		props: {
			tag,
			posts: posts.filter((post) => (post.data.tags ?? []).some((item) => item === tag)),
		},
	}));
}

const { tag, posts } = Astro.props;
const safeTag = typeof Astro.params.tag === 'string' ? Astro.params.tag : '';
const filteredPosts =
	posts?.filter((post) => (post.data.tags ?? []).some((item) => tagMatchesSlug(item, safeTag))) ?? [];
const structuredData = [
	{
		'@context': 'https://schema.org',
		'@type': 'CollectionPage',
		name: `태그: ${tag}`,
		description: `${tag} 태그로 분류된 글 모음입니다.`,
		url: `${SITE_URL}/tags/${safeTag}/`,
		inLanguage: 'ko-KR',
	},
	{
		'@context': 'https://schema.org',
		'@type': 'ItemList',
		itemListElement: filteredPosts.map((post, index) => ({
			'@type': 'ListItem',
			position: index + 1,
			url: `${SITE_URL}${getPostUrl(post)}`,
			name: post.data.title,
		})),
	},
];
---

<PageLayout
	title={`태그: ${tag}`}
	description={`${tag} 태그로 분류된 글 모음입니다.`}
	keywords={[tag, '태그', 'OpenClaw']}
	structuredData={structuredData}
>
	<section class="tag-page">
		<p class="eyebrow">TAG ARCHIVE</p>
		<h1>#{tag}</h1>
		<p class="lead">이 태그와 관련된 글 {filteredPosts.length}개를 모았습니다.</p>

		<div class="post-list">
			{filteredPosts.map((post) => (
				<article class="card">
					<a href={getPostUrl(post)}>
						<p class="meta">
							<FormattedDate date={post.data.pubDate} />
						</p>
						<h2>{post.data.title}</h2>
						<p>{post.data.description}</p>
					</a>
					<TagList tags={post.data.tags} />
				</article>
			))}
		</div>
	</section>
</PageLayout>

<style>
	.tag-page {
		display: grid;
		gap: 1rem;
	}

	.eyebrow {
		margin: 0;
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.2em;
		color: var(--accent);
	}

	h1 {
		color: var(--cream);
		font-family: "Playfair Display", Georgia, serif;
	}

	.lead {
		margin: 0 0 1rem;
		color: rgb(var(--gray));
	}

	.post-list {
		display: grid;
		gap: 1rem;
	}

	.card {
		display: grid;
		gap: 0.8rem;
		padding: 1.15rem;
		border: 1px solid rgba(var(--line), 0.3);
		border-radius: 12px;
		background: rgba(var(--surface-elevated), 0.7);
		transition: all 0.25s ease;
	}

	.card:hover {
		border-color: rgba(var(--line), 0.55);
		box-shadow: 0 8px 28px rgba(0, 0, 0, 0.2);
		transform: translateY(-1px);
	}

	.card h2 {
		font-family: "Playfair Display", Georgia, serif;
		color: rgb(var(--black));
		transition: color 0.2s ease;
	}

	.card:hover h2 {
		color: var(--cream);
	}

	.card a {
		text-decoration: none;
		color: inherit;
	}

	.card h2 {
		margin: 0.1rem 0 0.35rem;
		font-size: 1.35rem;
	}

	.card p {
		margin: 0;
	}

	.meta {
		font-size: 0.92rem;
		color: rgb(var(--gray));
	}
</style>
