---
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';
import TagList from '../../components/TagList.astro';
import PageLayout from '../../layouts/PageLayout.astro';
import { SITE_URL } from '../../consts';
import { getPostUrl, getTagSlug, isUsableTag, tagMatchesSlug } from '../../utils/blog';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	const tags = [
		...new Set(posts.flatMap((post) => (post.data.tags ?? []).filter((tag) => isUsableTag(tag)))),
	];
	return tags.map((tag) => ({
		params: { tag: getTagSlug(tag) },
		props: {
			tag,
			posts: posts.filter((post) => (post.data.tags ?? []).some((item) => item === tag)),
		},
	}));
}

const { tag, posts } = Astro.props;
const safeTag = typeof Astro.params.tag === 'string' ? Astro.params.tag : '';
const filteredPosts =
	posts?.filter((post) => (post.data.tags ?? []).some((item) => tagMatchesSlug(item, safeTag))) ?? [];
const structuredData = [
	{
		'@context': 'https://schema.org',
		'@type': 'CollectionPage',
		name: `태그: ${tag}`,
		description: `${tag} 태그로 분류된 글 모음입니다.`,
		url: `${SITE_URL}/tags/${safeTag}/`,
		inLanguage: 'ko-KR',
	},
	{
		'@context': 'https://schema.org',
		'@type': 'ItemList',
		itemListElement: filteredPosts.map((post, index) => ({
			'@type': 'ListItem',
			position: index + 1,
			url: `${SITE_URL}${getPostUrl(post)}`,
			name: post.data.title,
		})),
	},
];
---

<PageLayout
	title={`태그: ${tag}`}
	description={`${tag} 태그로 분류된 글 모음입니다.`}
	keywords={[tag, '태그', 'OpenClaw']}
	structuredData={structuredData}
>
	<section class="tag-page">
		<div class="tag-header">
			<p class="eyebrow">TAG ARCHIVE</p>
			<h1>#{tag}</h1>
			<p class="lead">이 태그와 관련된 글 {filteredPosts.length}개를 모았습니다.</p>
		</div>

		<div class="post-list">
			{filteredPosts.map((post) => (
				<article class="post-item">
					<a href={getPostUrl(post)}>
						<p class="meta">
							<FormattedDate date={post.data.pubDate} />
						</p>
						<h2>{post.data.title}</h2>
						<p class="desc">{post.data.description}</p>
					</a>
					<div class="post-tags">
						<TagList tags={post.data.tags} />
					</div>
				</article>
			))}
		</div>
	</section>
</PageLayout>

<style>
	.tag-page {
		display: grid;
		gap: 2rem;
	}

	.tag-header {
		display: grid;
		gap: 0.75rem;
	}

	.eyebrow {
		margin: 0;
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.18em;
		color: var(--accent);
	}

	.lead {
		margin: 0;
		color: rgb(var(--gray));
		font-size: 0.95rem;
	}

	/* Border-separated list instead of cards */
	.post-list {
		display: grid;
		gap: 0;
	}

	.post-item {
		padding: 1.15rem 0;
		border-bottom: 1px solid rgba(var(--line), 0.4);
		transition: var(--transition-fast);
	}

	.post-item:first-child {
		border-top: 1px solid rgba(var(--line), 0.4);
	}

	.post-item:hover {
		background: rgba(var(--gray-light), 0.15);
		padding-left: 0.75rem;
		padding-right: 0.75rem;
		border-radius: 10px;
	}

	.post-item a {
		text-decoration: none;
		color: inherit;
	}

	.post-item h2 {
		margin: 0.1rem 0 0.3rem;
		font-size: 1.2rem;
		font-weight: 600;
	}

	.post-item p {
		margin: 0;
	}

	.desc {
		color: rgb(var(--gray));
		font-size: 0.9rem;
		line-height: 1.55;
		max-width: 65ch;
	}

	.meta {
		font-size: 0.82rem;
		color: rgb(var(--gray));
	}

	.post-tags {
		margin-top: 0.5rem;
	}
</style>
