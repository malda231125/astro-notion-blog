---
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';
import TagList from '../../components/TagList.astro';
import PageLayout from '../../layouts/PageLayout.astro';
import { SITE_URL } from '../../consts';
import { getPostUrl, getTagSlug, isUsableTag, tagMatchesSlug } from '../../utils/blog';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	const tags = [
		...new Set(posts.flatMap((post) => (post.data.tags ?? []).filter((tag) => isUsableTag(tag)))),
	];
	return tags.map((tag) => ({
		params: { tag: getTagSlug(tag) },
		props: {
			tag,
			posts: posts.filter((post) => (post.data.tags ?? []).some((item) => item === tag)),
		},
	}));
}

const { tag, posts } = Astro.props;
const safeTag = typeof Astro.params.tag === 'string' ? Astro.params.tag : '';
const filteredPosts =
	posts?.filter((post) => (post.data.tags ?? []).some((item) => tagMatchesSlug(item, safeTag))) ?? [];
const structuredData = [
	{
		'@context': 'https://schema.org',
		'@type': 'CollectionPage',
		name: `태그: ${tag}`,
		description: `${tag} 태그로 분류된 글 모음입니다.`,
		url: `${SITE_URL}/tags/${safeTag}/`,
		inLanguage: 'ko-KR',
	},
	{
		'@context': 'https://schema.org',
		'@type': 'ItemList',
		itemListElement: filteredPosts.map((post, index) => ({
			'@type': 'ListItem',
			position: index + 1,
			url: `${SITE_URL}${getPostUrl(post)}`,
			name: post.data.title,
		})),
	},
];
---

<PageLayout
	title={`태그: ${tag}`}
	description={`${tag} 태그로 분류된 글 모음입니다.`}
	keywords={[tag, '태그', 'OpenClaw']}
	structuredData={structuredData}
>
	<section class="tag-page">
		<div class="tag-badge">TAG ARCHIVE</div>
		<h1>#{tag}</h1>
		<p class="lead">이 태그와 관련된 글 {filteredPosts.length}개를 모았습니다.</p>

		<div class="post-list">
			{filteredPosts.map((post, i) => (
				<article class="card" style={`animation-delay: ${i * 60}ms`}>
					<a href={getPostUrl(post)}>
						<div class="card-body">
							<p class="meta">
								<FormattedDate date={post.data.pubDate} />
							</p>
							<h2>{post.data.title}</h2>
							<p class="card-desc">{post.data.description}</p>
						</div>
					</a>
					<div class="card-footer">
						<TagList tags={post.data.tags} />
					</div>
				</article>
			))}
		</div>
	</section>
</PageLayout>

<style>
	.tag-page {
		display: grid;
		gap: 1rem;
	}

	.tag-badge {
		display: inline-flex;
		align-items: center;
		padding: 0.35rem 0.75rem;
		border-radius: 999px;
		background: rgba(99, 102, 241, 0.08);
		border: 1px solid rgba(99, 102, 241, 0.15);
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		color: var(--accent);
		width: fit-content;
	}

	.lead {
		margin: 0 0 1.5rem;
		color: rgb(var(--gray));
		font-size: 0.95rem;
	}

	.post-list {
		display: grid;
		gap: 1rem;
	}

	.card {
		display: flex;
		flex-direction: column;
		border: 1px solid rgba(var(--line), 0.35);
		border-radius: 16px;
		background: rgba(255, 255, 255, 0.8);
		box-shadow: var(--shadow);
		overflow: hidden;
		transition: box-shadow var(--transition-normal), transform var(--transition-normal), border-color var(--transition-normal);
		animation: fadeInUp 0.5s var(--ease-out) both;
	}

	.card:hover {
		box-shadow: var(--shadow-lg);
		transform: translateY(-3px);
		border-color: rgba(99, 102, 241, 0.2);
	}

	.card a {
		text-decoration: none;
		color: inherit;
	}

	.card-body {
		padding: 1.15rem 1.25rem 0.5rem;
	}

	.card h2 {
		margin: 0.15rem 0 0.4rem;
		font-size: 1.3rem;
		line-height: 1.35;
		transition: color var(--transition-fast);
	}

	.card:hover h2 {
		color: var(--accent);
	}

	.card-desc {
		margin: 0;
		font-size: 0.92rem;
		color: rgb(var(--gray));
		line-height: 1.55;
	}

	.card-footer {
		padding: 0.65rem 1.25rem 1.1rem;
		margin-top: auto;
	}

	.meta {
		font-size: 0.85rem;
		color: rgb(var(--gray));
	}
</style>
