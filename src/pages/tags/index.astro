---
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import { SITE_URL } from '../../consts';
import { getAllTags, getTagUrl } from '../../utils/blog';

const posts = await getCollection('blog');
const tags = getAllTags(posts);
const structuredData = {
	'@context': 'https://schema.org',
	'@type': 'CollectionPage',
	name: '태그 모음',
	description: '블로그 글을 태그별로 탐색할 수 있는 허브 페이지입니다.',
	url: `${SITE_URL}/tags/`,
	inLanguage: 'ko-KR',
};
---

<PageLayout
	title="태그 모음"
	description="블로그 글을 태그별로 탐색할 수 있는 허브 페이지입니다."
	keywords={['태그', 'OpenClaw', 'AI 에이전트']}
	structuredData={structuredData}
>
	<section class="tags-page">
		<div class="tags-header">
			<p class="eyebrow">TOPIC HUB</p>
			<h1>태그별 글 모아보기</h1>
			<p class="lead">주제별로 쌓인 글을 빠르게 탐색할 수 있도록 태그 허브를 구성했습니다.</p>
		</div>

		<ul class="tag-grid stagger-in" aria-label="태그 목록">
			{tags.map((tag) => {
				const count = posts.filter((post) => (post.data.tags ?? []).includes(tag)).length;
				return (
					<li>
						<a href={getTagUrl(tag)}>
							<strong>#{tag}</strong>
							<span>{count}개의 글</span>
						</a>
					</li>
				);
			})}
		</ul>
	</section>
</PageLayout>

<style>
	.tags-page {
		display: grid;
		gap: 2rem;
	}

	.tags-header {
		display: grid;
		gap: 0.75rem;
	}

	.eyebrow {
		margin: 0;
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.18em;
		color: var(--accent);
	}

	h1 {
		max-width: 20ch;
	}

	.lead {
		margin: 0;
		color: rgb(var(--gray));
		font-size: 0.95rem;
		max-width: 55ch;
	}

	/* 2-column asymmetric layout for tags */
	.tag-grid {
		display: grid;
		grid-template-columns: 1.1fr 1fr;
		gap: 0.75rem;
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.tag-grid li {
		margin: 0;
	}

	.tag-grid a {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 0.85rem 1.1rem;
		border-radius: 12px;
		border: 1px solid rgba(var(--line), 0.4);
		background: #fff;
		text-decoration: none;
		color: rgb(var(--gray-dark));
		transition: var(--transition-base);
	}

	.tag-grid a:hover {
		border-color: rgba(var(--line), 0.7);
		box-shadow: var(--shadow);
		color: rgb(var(--black));
	}

	.tag-grid a:active {
		transform: translateY(1px) scale(0.98);
	}

	.tag-grid strong {
		font-size: 0.98rem;
		font-weight: 600;
	}

	.tag-grid span {
		color: rgb(var(--gray));
		font-size: 0.85rem;
	}

	@media (max-width: 640px) {
		.tag-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
