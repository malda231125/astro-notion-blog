---
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import { SITE_URL } from '../../consts';
import { getAllTags, getTagUrl } from '../../utils/blog';

const posts = await getCollection('blog');
const tags = getAllTags(posts);
const structuredData = {
	'@context': 'https://schema.org',
	'@type': 'CollectionPage',
	name: '태그 모음',
	description: '블로그 글을 태그별로 탐색할 수 있는 허브 페이지입니다.',
	url: `${SITE_URL}/tags/`,
	inLanguage: 'ko-KR',
};
---

<PageLayout
	title="태그 모음"
	description="블로그 글을 태그별로 탐색할 수 있는 허브 페이지입니다."
	keywords={['태그', 'OpenClaw', 'AI 에이전트']}
	structuredData={structuredData}
>
	<section class="tags-page">
		<p class="eyebrow">TOPIC HUB</p>
		<h1>태그별 글 모아보기</h1>
		<p class="lead">주제별로 쌓인 글을 빠르게 탐색할 수 있도록 태그 허브를 구성했습니다.</p>

		<ul class="tag-grid" aria-label="태그 목록">
			{tags.map((tag) => {
				const count = posts.filter((post) => (post.data.tags ?? []).includes(tag)).length;
				return (
					<li>
						<a href={getTagUrl(tag)}>
							<strong>#{tag}</strong>
							<span>{count}개의 글</span>
						</a>
					</li>
				);
			})}
		</ul>
	</section>
</PageLayout>

<style>
	.tags-page {
		display: grid;
		gap: 1rem;
	}

	.eyebrow {
		margin: 0;
		font-size: 0.78rem;
		font-weight: 800;
		letter-spacing: 0.16em;
		color: var(--accent);
		text-transform: uppercase;
	}

	.lead {
		margin: 0 0 1.25rem;
		color: rgb(var(--gray));
		font-size: 0.95rem;
	}

	.tag-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 0.85rem;
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.tag-grid li {
		margin: 0;
	}

	.tag-grid a {
		display: grid;
		gap: 0.3rem;
		padding: 1.15rem;
		border-radius: var(--radius-lg, 22px);
		border: 1px solid rgba(var(--line), 0.25);
		background: rgba(255, 255, 255, 0.7);
		box-shadow: var(--shadow-sm, 0 1px 3px rgba(0,0,0,0.06));
		text-decoration: none;
		color: rgb(var(--gray-dark));
		transition: box-shadow 200ms ease, transform 200ms ease, border-color 200ms ease;
	}

	.tag-grid a:hover {
		box-shadow: var(--shadow, 0 8px 24px rgba(0,0,0,0.08));
		transform: translateY(-2px);
		border-color: rgba(26, 107, 82, 0.2);
	}

	.tag-grid strong {
		font-size: 1.05rem;
		transition: color 150ms ease;
	}

	.tag-grid a:hover strong {
		color: var(--accent);
	}

	.tag-grid span {
		color: rgb(var(--gray));
		font-size: 0.88rem;
	}

	@media (max-width: 900px) {
		.tag-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 520px) {
		.tag-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
