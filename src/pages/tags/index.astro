---
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import { SITE_URL } from '../../consts';
import { getAllTags, getTagUrl } from '../../utils/blog';

const posts = await getCollection('blog');
const tags = getAllTags(posts);
const structuredData = {
	'@context': 'https://schema.org',
	'@type': 'CollectionPage',
	name: '태그 모음',
	description: '블로그 글을 태그별로 탐색할 수 있는 허브 페이지입니다.',
	url: `${SITE_URL}/tags/`,
	inLanguage: 'ko-KR',
};
---

<PageLayout
	title="태그 모음"
	description="블로그 글을 태그별로 탐색할 수 있는 허브 페이지입니다."
	keywords={['태그', 'OpenClaw', 'AI 에이전트']}
	structuredData={structuredData}
>
	<section class="tags-page">
		<div class="tags-badge">TOPIC HUB</div>
		<h1>태그별 글 모아보기</h1>
		<p class="lead">주제별로 쌓인 글을 빠르게 탐색할 수 있도록 태그 허브를 구성했습니다.</p>

		<ul class="tag-grid" aria-label="태그 목록">
			{tags.map((tag, i) => {
				const count = posts.filter((post) => (post.data.tags ?? []).includes(tag)).length;
				return (
					<li style={`animation-delay: ${i * 50}ms`}>
						<a href={getTagUrl(tag)}>
							<div class="tag-icon">
								<svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M2 8.5l4.5 5L14 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
							</div>
							<div>
								<strong>#{tag}</strong>
								<span>{count}개의 글</span>
							</div>
						</a>
					</li>
				);
			})}
		</ul>
	</section>
</PageLayout>

<style>
	.tags-page {
		display: grid;
		gap: 1rem;
	}

	.tags-badge {
		display: inline-flex;
		align-items: center;
		padding: 0.35rem 0.75rem;
		border-radius: 999px;
		background: rgba(99, 102, 241, 0.08);
		border: 1px solid rgba(99, 102, 241, 0.15);
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		color: var(--accent);
		width: fit-content;
	}

	.lead {
		margin: 0 0 1.5rem;
		color: rgb(var(--gray));
		font-size: 0.95rem;
	}

	.tag-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 0.85rem;
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.tag-grid li {
		margin: 0;
		animation: fadeInUp 0.5s var(--ease-out) both;
	}

	.tag-grid a {
		display: flex;
		align-items: center;
		gap: 0.85rem;
		padding: 1.1rem 1.15rem;
		border-radius: 14px;
		border: 1px solid rgba(var(--line), 0.35);
		background: rgba(255, 255, 255, 0.8);
		box-shadow: var(--shadow);
		text-decoration: none;
		color: rgb(var(--gray-dark));
		transition: box-shadow var(--transition-normal), transform var(--transition-normal), border-color var(--transition-normal);
	}

	.tag-grid a:hover {
		box-shadow: var(--shadow-lg);
		transform: translateY(-2px);
		border-color: rgba(99, 102, 241, 0.25);
	}

	.tag-icon {
		display: grid;
		place-items: center;
		width: 2rem;
		height: 2rem;
		border-radius: 8px;
		background: rgba(99, 102, 241, 0.08);
		color: var(--accent);
		flex-shrink: 0;
	}

	.tag-grid strong {
		display: block;
		font-size: 1rem;
		color: rgb(var(--black));
		transition: color var(--transition-fast);
	}

	.tag-grid a:hover strong {
		color: var(--accent);
	}

	.tag-grid span {
		display: block;
		color: rgb(var(--gray));
		font-size: 0.85rem;
		margin-top: 0.15rem;
	}

	@media (max-width: 900px) {
		.tag-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 560px) {
		.tag-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
