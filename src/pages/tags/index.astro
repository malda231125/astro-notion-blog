---
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import { SITE_URL } from '../../consts';
import { getAllTags, getTagUrl } from '../../utils/blog';

const posts = await getCollection('blog');
const tags = getAllTags(posts);
const structuredData = {
	'@context': 'https://schema.org',
	'@type': 'CollectionPage',
	name: '태그 모음',
	description: '블로그 글을 태그별로 탐색할 수 있는 허브 페이지입니다.',
	url: `${SITE_URL}/tags/`,
	inLanguage: 'ko-KR',
};
---

<PageLayout
	title="태그 모음"
	description="블로그 글을 태그별로 탐색할 수 있는 허브 페이지입니다."
	keywords={['태그', 'OpenClaw', 'AI 에이전트']}
	structuredData={structuredData}
>
	<section class="tags-page">
		<div class="tags-header">
			<p class="eyebrow">TOPIC HUB</p>
			<h1>태그별 글 모아보기</h1>
			<p class="lead">주제별로 쌓인 글을 빠르게 탐색할 수 있도록 태그 허브를 구성했습니다.</p>
		</div>

		<ul class="tag-grid" aria-label="태그 목록">
			{tags.map((tag, i) => {
				const count = posts.filter((post) => (post.data.tags ?? []).includes(tag)).length;
				return (
					<li style={`animation-delay: ${i * 30}ms`}>
						<a href={getTagUrl(tag)}>
							<strong>#{tag}</strong>
							<span>{count}개의 글</span>
						</a>
					</li>
				);
			})}
		</ul>
	</section>
</PageLayout>

<style>
	.tags-page {
		display: grid;
		gap: var(--space-xl);
	}

	.tags-header {
		display: grid;
		gap: 0.75rem;
	}

	.eyebrow {
		margin: 0;
		font-size: 0.78rem;
		font-weight: 800;
		letter-spacing: 0.14em;
		color: var(--accent);
	}

	.tags-header h1 {
		margin: 0;
	}

	.lead {
		margin: 0;
		color: rgb(var(--gray));
		line-height: 1.65;
	}

	.tag-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: var(--space-md);
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.tag-grid li {
		margin: 0;
	}

	.tag-grid a {
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
		padding: var(--space-lg);
		border-radius: var(--radius-lg);
		border: 1px solid rgba(var(--line), 0.35);
		background: rgba(255, 255, 255, 0.72);
		box-shadow: var(--shadow-sm);
		backdrop-filter: blur(10px);
		-webkit-backdrop-filter: blur(10px);
		text-decoration: none;
		color: rgb(var(--gray-dark));
		transition: box-shadow var(--duration-base) var(--ease-out),
			transform var(--duration-base) var(--ease-out),
			border-color var(--duration-base) var(--ease-out);
	}

	.tag-grid a:hover {
		box-shadow: var(--shadow);
		transform: translateY(-3px);
		border-color: rgba(var(--accent-rgb), 0.2);
	}

	.tag-grid a:hover strong {
		color: var(--accent);
	}

	.tag-grid strong {
		font-size: 1.1rem;
		color: rgb(var(--black));
		transition: color var(--duration-fast) var(--ease-out);
	}

	.tag-grid span {
		color: rgb(var(--gray));
		font-size: 0.9rem;
	}

	@media (max-width: 900px) {
		.tag-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 520px) {
		.tag-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
