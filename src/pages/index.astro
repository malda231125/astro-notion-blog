---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';
import TagList from '../components/TagList.astro';
import {
	GITHUB_REPO_URL,
	SITE_BRAND_NAME,
	SITE_DESCRIPTION,
	SITE_SECTION_DESCRIPTION,
	SITE_TITLE,
	SITE_URL,
} from '../consts';
import PageLayout from '../layouts/PageLayout.astro';
import { getAllTags, getPostUrl, sortBlogPosts } from '../utils/blog';

const posts = sortBlogPosts(await getCollection('blog'));
const featuredPosts = posts.slice(0, 3);
const latestPosts = posts.slice(3, 9);
const tags = getAllTags(posts).slice(0, 8);

const structuredData = [
	{
		'@context': 'https://schema.org',
		'@type': 'WebSite',
		name: SITE_TITLE,
		description: SITE_DESCRIPTION,
		url: `${SITE_URL}/`,
		inLanguage: 'ko-KR',
	},
	{
		'@context': 'https://schema.org',
		'@type': 'Organization',
		name: SITE_BRAND_NAME,
		url: SITE_URL,
		sameAs: [GITHUB_REPO_URL],
	},
];
---

<PageLayout
	title={SITE_TITLE}
	description={SITE_DESCRIPTION}
	keywords={['OpenClaw', 'AI 에이전트', '자동화', '홈서버', 'SEO']}
	structuredData={structuredData}
>
	<section class="hero card-surface">
		<div class="hero-copy">
			<p class="eyebrow">OPENCLAW · AI AGENTS · AUTOMATION</p>
			<h1>OpenClaw와 AI 에이전트 운영 인사이트를 축적하는 블로그</h1>
			<p class="lead">{SITE_SECTION_DESCRIPTION}</p>
			<div class="hero-links">
				<a class="primary" href="/blog">전체 글 보기</a>
				<a class="secondary" href="/about">블로그 소개</a>
			</div>
		</div>
		<aside class="hero-panel" aria-label="블로그 개요">
			<p class="panel-label">EDITORIAL FOCUS</p>
			<div class="hero-stats">
				<div>
					<span>대표 주제</span>
					<strong>OpenClaw 운영</strong>
				</div>
				<div>
					<span>콘텐츠 형태</span>
					<strong>트렌드 · 설치 · 배포</strong>
				</div>
			</div>
			<ul>
				<li>릴리즈와 생태계 변화를 빠르게 정리합니다.</li>
				<li>실사용 운영 관점에서 설치·배포·자동화를 아카이브합니다.</li>
				<li>검색과 재탐색이 쉬운 구조로 태그/시리즈를 정리합니다.</li>
			</ul>
		</aside>
	</section>

	{tags.length > 0 && (
		<section class="topic-strip" aria-labelledby="topic-strip-title">
			<div class="section-heading">
				<h2 id="topic-strip-title">주요 토픽</h2>
				<p>콘텐츠가 쌓일수록 태그 허브와 시리즈 구조를 함께 정리합니다.</p>
			</div>
			<TagList tags={tags} />
		</section>
	)}

	<section class="featured" aria-labelledby="featured-title">
		<div class="section-heading">
			<h2 id="featured-title">대표 글</h2>
			<p>먼저 읽기 좋은 최근 글과 운영 기록입니다.</p>
		</div>
		<div class="featured-grid">
			{featuredPosts.map((post, i) => (
				<article class="card featured-card" style={`animation-delay: ${i * 0.1}s`}>
					<a href={getPostUrl(post)}>
						{post.data.heroImage && (
							<Image width={720} height={360} src={post.data.heroImage} alt={post.data.title} />
						)}
						<p class="meta">
							<FormattedDate date={post.data.pubDate} />
						</p>
						<h3>{post.data.title}</h3>
						<p>{post.data.description}</p>
					</a>
					<TagList tags={post.data.tags} />
				</article>
			))}
		</div>
	</section>

	{latestPosts.length > 0 && (
		<section aria-labelledby="latest-title">
			<div class="section-heading">
				<h2 id="latest-title">최신 업데이트</h2>
				<p>릴리즈 분석, 트렌드 정리, 운영 메모를 최신순으로 모았습니다.</p>
			</div>
			<div class="list-grid">
				{latestPosts.map((post, i) => (
					<article class="card compact-card" style={`animation-delay: ${i * 0.08}s`}>
						<a href={getPostUrl(post)}>
							<p class="meta">
								<FormattedDate date={post.data.pubDate} />
							</p>
							<h3>{post.data.title}</h3>
							<p>{post.data.description}</p>
						</a>
						<TagList tags={post.data.tags} />
					</article>
				))}
			</div>
		</section>
	)}
</PageLayout>

<style>
	/* Hero Section */
	.hero {
		display: grid;
		grid-template-columns: minmax(0, 1.15fr) minmax(280px, 0.85fr);
		gap: 2rem;
		align-items: start;
		padding: 2.5rem;
		border-radius: 16px;
		position: relative;
		overflow: hidden;
		animation: fadeUp 0.7s ease both;
	}

	.hero::before {
		content: "";
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 3px;
		background: linear-gradient(90deg, var(--accent), var(--highlight), transparent);
	}

	.hero-copy {
		display: grid;
		gap: 1rem;
		animation: slideInLeft 0.8s ease both;
		animation-delay: 0.15s;
	}

	.eyebrow {
		margin: 0;
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.2em;
		color: var(--accent);
	}

	.hero h1 {
		max-width: 16ch;
		margin: 0;
		font-size: clamp(2.4rem, 4.5vw, 3.8rem);
		line-height: 1.08;
		color: var(--cream);
	}

	.lead {
		max-width: 62ch;
		margin: 0;
		font-size: 1.02rem;
		color: rgb(var(--gray));
		line-height: 1.7;
	}

	.hero-links {
		display: flex;
		gap: 0.8rem;
		flex-wrap: wrap;
		margin-top: 0.5rem;
	}

	.hero-links a {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.75rem 1.15rem;
		border-radius: 6px;
		text-decoration: none;
		font-weight: 600;
		font-size: 0.92rem;
		letter-spacing: 0.01em;
		transition: all 0.25s ease;
	}

	.hero-links .primary {
		background: var(--accent);
		color: #fff;
		box-shadow: 0 4px 16px rgba(200, 69, 62, 0.25);
	}

	.hero-links .primary:hover {
		background: var(--accent-dark);
		box-shadow: 0 6px 24px rgba(200, 69, 62, 0.35);
		transform: translateY(-1px);
	}

	.hero-links .secondary {
		background: transparent;
		border: 1px solid rgba(var(--line), 0.6);
		color: rgb(var(--gray-dark));
	}

	.hero-links .secondary:hover {
		border-color: rgba(var(--line), 1);
		color: rgb(var(--black));
	}

	/* Hero Panel */
	.hero-panel {
		padding: 1.5rem;
		border-radius: 12px;
		background: rgba(var(--surface-soft), 0.8);
		border: 1px solid rgba(var(--line), 0.35);
		animation: fadeUp 0.8s ease both;
		animation-delay: 0.3s;
	}

	.panel-label {
		margin: 0 0 1rem;
		font-size: 0.68rem;
		font-weight: 700;
		letter-spacing: 0.18em;
		color: var(--accent);
		text-transform: uppercase;
	}

	.hero-stats {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.75rem;
		margin-bottom: 1rem;
	}

	.hero-stats div {
		padding: 0.85rem;
		border-radius: 8px;
		background: rgba(var(--surface-elevated), 0.9);
		border: 1px solid rgba(var(--line), 0.3);
	}

	.hero-stats span {
		display: block;
		font-size: 0.75rem;
		color: rgb(var(--gray));
		margin-bottom: 0.3rem;
		letter-spacing: 0.02em;
	}

	.hero-stats strong {
		display: block;
		line-height: 1.25;
		color: rgb(var(--black));
		font-size: 0.92rem;
	}

	.hero-panel ul {
		margin: 0;
		padding-left: 1.1rem;
		color: rgb(var(--gray));
		font-size: 0.88rem;
		line-height: 1.65;
	}

	.hero-panel li {
		margin: 0.3rem 0;
	}

	/* Section Headings */
	.section-heading {
		margin-bottom: 1.25rem;
		position: relative;
	}

	.section-heading h2 {
		color: var(--cream);
		font-family: "Playfair Display", Georgia, serif;
		position: relative;
		display: inline-block;
	}

	.section-heading h2::after {
		content: "";
		display: block;
		width: 2rem;
		height: 2px;
		background: var(--accent);
		margin-top: 0.4rem;
	}

	.section-heading p {
		margin: 0.4rem 0 0;
		color: rgb(var(--gray));
		font-size: 0.92rem;
	}

	/* Sections spacing */
	.topic-strip,
	.featured,
	section[aria-labelledby='latest-title'] {
		margin-top: 3rem;
		animation: fadeUp 0.6s ease both;
	}

	.featured {
		animation-delay: 0.1s;
	}

	section[aria-labelledby='latest-title'] {
		animation-delay: 0.2s;
	}

	/* Grids */
	.featured-grid,
	.list-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
	}

	/* Cards */
	.card {
		display: grid;
		gap: 0.8rem;
		padding: 1.25rem;
		border: 1px solid rgba(var(--line), 0.3);
		border-radius: 12px;
		background: rgba(var(--surface-elevated), 0.7);
		box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
		backdrop-filter: blur(10px);
		transition: all 0.3s ease;
		animation: fadeUp 0.5s ease both;
	}

	.card:hover {
		border-color: rgba(var(--line), 0.55);
		box-shadow: 0 8px 32px rgba(0, 0, 0, 0.25);
		transform: translateY(-2px);
	}

	.card a {
		text-decoration: none;
		color: inherit;
	}

	.card img {
		width: 100%;
		height: auto;
		border-radius: 8px;
		transition: opacity 0.3s ease;
	}

	.card:hover img {
		opacity: 0.9;
	}

	.card h3 {
		margin: 0.2rem 0 0.4rem;
		font-size: 1.1rem;
		color: rgb(var(--black));
		transition: color 0.2s ease;
		font-family: "Playfair Display", Georgia, serif;
		line-height: 1.3;
	}

	.card:hover h3 {
		color: var(--cream);
	}

	.card p {
		margin: 0;
		font-size: 0.9rem;
		color: rgb(var(--gray));
		line-height: 1.55;
	}

	.meta {
		font-size: 0.82rem;
		color: rgb(var(--gray));
		letter-spacing: 0.01em;
	}

	/* Compact cards for latest */
	.compact-card {
		padding: 1.1rem;
	}

	.compact-card h3 {
		font-size: 1rem;
	}

	@media (max-width: 900px) {
		.hero {
			grid-template-columns: 1fr;
			padding: 1.5rem;
		}

		.featured-grid,
		.list-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
