---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';
import TagList from '../components/TagList.astro';
import {
	GITHUB_REPO_URL,
	SITE_BRAND_NAME,
	SITE_DESCRIPTION,
	SITE_SECTION_DESCRIPTION,
	SITE_TITLE,
	SITE_URL,
} from '../consts';
import PageLayout from '../layouts/PageLayout.astro';
import { getAllTags, getPostUrl, sortBlogPosts } from '../utils/blog';

const posts = sortBlogPosts(await getCollection('blog'));
const featuredPosts = posts.slice(0, 3);
const latestPosts = posts.slice(3, 9);
const tags = getAllTags(posts).slice(0, 8);

const structuredData = [
	{
		'@context': 'https://schema.org',
		'@type': 'WebSite',
		name: SITE_TITLE,
		description: SITE_DESCRIPTION,
		url: `${SITE_URL}/`,
		inLanguage: 'ko-KR',
	},
	{
		'@context': 'https://schema.org',
		'@type': 'Organization',
		name: SITE_BRAND_NAME,
		url: SITE_URL,
		sameAs: [GITHUB_REPO_URL],
	},
];
---

<PageLayout
	title={SITE_TITLE}
	description={SITE_DESCRIPTION}
	keywords={['OpenClaw', 'AI 에이전트', '자동화', '홈서버', 'SEO']}
	structuredData={structuredData}
>
	<section class="hero">
		<p class="eyebrow">OPENCLAW · AI AGENTS · AUTOMATION</p>
		<h1>OpenClaw와 AI 에이전트 운영 인사이트를 축적하는 블로그</h1>
		<p class="lead">{SITE_SECTION_DESCRIPTION}</p>
		<div class="hero-links">
			<a class="primary" href="/blog">전체 글 보기</a>
			<a class="secondary" href="/about">블로그 소개</a>
		</div>
	</section>

	{tags.length > 0 && (
		<section class="topic-strip" aria-labelledby="topic-strip-title">
			<div class="section-heading">
				<h2 id="topic-strip-title">주요 토픽</h2>
				<p>콘텐츠가 쌓일수록 태그 허브와 시리즈 구조를 함께 정리합니다.</p>
			</div>
			<TagList tags={tags} />
		</section>
	)}

	<section class="featured" aria-labelledby="featured-title">
		<div class="section-heading">
			<h2 id="featured-title">대표 글</h2>
			<p>먼저 읽기 좋은 최근 글과 운영 기록입니다.</p>
		</div>
		<div class="featured-grid">
			{featuredPosts.map((post) => (
				<article class="card featured-card">
					<a href={getPostUrl(post)}>
						{post.data.heroImage && (
							<Image width={720} height={360} src={post.data.heroImage} alt={post.data.title} />
						)}
						<p class="meta">
							<FormattedDate date={post.data.pubDate} />
						</p>
						<h3>{post.data.title}</h3>
						<p>{post.data.description}</p>
					</a>
					<TagList tags={post.data.tags} />
				</article>
			))}
		</div>
	</section>

	{latestPosts.length > 0 && (
		<section aria-labelledby="latest-title">
			<div class="section-heading">
				<h2 id="latest-title">최신 업데이트</h2>
				<p>릴리즈 분석, 트렌드 정리, 운영 메모를 최신순으로 모았습니다.</p>
			</div>
			<div class="list-grid">
				{latestPosts.map((post) => (
					<article class="card compact-card">
						<a href={getPostUrl(post)}>
							<p class="meta">
								<FormattedDate date={post.data.pubDate} />
							</p>
							<h3>{post.data.title}</h3>
							<p>{post.data.description}</p>
						</a>
						<TagList tags={post.data.tags} />
					</article>
				))}
			</div>
		</section>
	)}
</PageLayout>

<style>
	.hero {
		display: grid;
		gap: 1rem;
		padding: 2rem 0 1.5rem;
	}

	.eyebrow {
		margin: 0;
		font-size: 0.82rem;
		font-weight: 800;
		letter-spacing: 0.14em;
		color: rgb(var(--gray));
	}

	.hero h1 {
		max-width: 820px;
		margin: 0;
	}

	.lead {
		max-width: 760px;
		margin: 0;
		font-size: 1.08rem;
		color: rgb(var(--gray-dark));
	}

	.hero-links {
		display: flex;
		gap: 0.8rem;
		flex-wrap: wrap;
	}

	.hero-links a {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.8rem 1rem;
		border-radius: 12px;
		text-decoration: none;
		font-weight: 700;
	}

	.hero-links .primary {
		background: var(--accent);
		color: #fff;
	}

	.hero-links .secondary {
		background: #fff;
		border: 1px solid rgb(var(--gray-light));
		color: rgb(var(--gray-dark));
	}

	.section-heading {
		margin-bottom: 1rem;
	}

	.section-heading p {
		margin: 0;
		color: rgb(var(--gray));
	}

	.topic-strip,
	.featured,
	section[aria-labelledby='latest-title'] {
		margin-top: 2rem;
	}

	.featured-grid,
	.list-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
	}

	.card {
		display: grid;
		gap: 0.8rem;
		padding: 1rem;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 18px;
		background: rgba(255, 255, 255, 0.9);
	}

	.card a {
		text-decoration: none;
		color: inherit;
	}

	.card img {
		width: 100%;
		height: auto;
		border-radius: 14px;
	}

	.card h3 {
		margin: 0.2rem 0 0.4rem;
		font-size: 1.2rem;
	}

	.card p {
		margin: 0;
	}

	.meta {
		font-size: 0.92rem;
		color: rgb(var(--gray));
	}

	@media (max-width: 900px) {
		.featured-grid,
		.list-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
