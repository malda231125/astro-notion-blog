---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';
import TagList from '../components/TagList.astro';
import {
	GITHUB_REPO_URL,
	SITE_BRAND_NAME,
	SITE_DESCRIPTION,
	SITE_SECTION_DESCRIPTION,
	SITE_TITLE,
	SITE_URL,
} from '../consts';
import PageLayout from '../layouts/PageLayout.astro';
import { getAllTags, getPostUrl, sortBlogPosts } from '../utils/blog';

const posts = sortBlogPosts(await getCollection('blog'));
const featuredPosts = posts.slice(0, 3);
const latestPosts = posts.slice(3, 9);
const tags = getAllTags(posts).slice(0, 8);

const structuredData = [
	{
		'@context': 'https://schema.org',
		'@type': 'WebSite',
		name: SITE_TITLE,
		description: SITE_DESCRIPTION,
		url: `${SITE_URL}/`,
		inLanguage: 'ko-KR',
	},
	{
		'@context': 'https://schema.org',
		'@type': 'Organization',
		name: SITE_BRAND_NAME,
		url: SITE_URL,
		sameAs: [GITHUB_REPO_URL],
	},
];
---

<PageLayout
	title={SITE_TITLE}
	description={SITE_DESCRIPTION}
	keywords={['OpenClaw', 'AI 에이전트', '자동화', '홈서버', 'SEO']}
	structuredData={structuredData}
>
	<section class="hero">
		<div class="hero-glow"></div>
		<div class="hero-content">
			<div class="hero-copy">
				<div class="badge">
					<span class="badge-dot"></span>
					AI AGENTS &middot; AUTOMATION &middot; ARCHIVE
				</div>
				<h1>OpenClaw와 AI 에이전트 운영 인사이트를 축적하는 블로그</h1>
				<p class="lead">{SITE_SECTION_DESCRIPTION}</p>
				<div class="hero-actions">
					<a class="btn btn-primary" href="/blog">
						전체 글 보기
						<svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
					</a>
					<a class="btn btn-ghost" href="/about">블로그 소개</a>
				</div>
			</div>
			<aside class="hero-panel" aria-label="블로그 개요">
				<p class="panel-label">EDITORIAL FOCUS</p>
				<div class="hero-stats">
					<div class="stat-card">
						<span class="stat-label">대표 주제</span>
						<strong>OpenClaw 운영</strong>
					</div>
					<div class="stat-card">
						<span class="stat-label">콘텐츠 형태</span>
						<strong>트렌드 &middot; 설치 &middot; 배포</strong>
					</div>
				</div>
				<ul>
					<li>릴리즈와 생태계 변화를 빠르게 정리합니다.</li>
					<li>실사용 운영 관점에서 설치&middot;배포&middot;자동화를 아카이브합니다.</li>
					<li>검색과 재탐색이 쉬운 구조로 태그/시리즈를 정리합니다.</li>
				</ul>
			</aside>
		</div>
	</section>

	{tags.length > 0 && (
		<section class="topic-strip" aria-labelledby="topic-strip-title">
			<div class="section-heading">
				<h2 id="topic-strip-title">주요 토픽</h2>
				<p>콘텐츠가 쌓일수록 태그 허브와 시리즈 구조를 함께 정리합니다.</p>
			</div>
			<TagList tags={tags} />
		</section>
	)}

	<section class="featured" aria-labelledby="featured-title">
		<div class="section-heading">
			<h2 id="featured-title">대표 글</h2>
			<p>먼저 읽기 좋은 최근 글과 운영 기록입니다.</p>
		</div>
		<div class="featured-grid">
			{featuredPosts.map((post, i) => (
				<article class="card featured-card" style={`animation-delay: ${i * 80}ms`}>
					<a href={getPostUrl(post)}>
						{post.data.heroImage && (
							<div class="card-image">
								<Image width={720} height={360} src={post.data.heroImage} alt={post.data.title} />
							</div>
						)}
						<div class="card-body">
							<p class="meta">
								<FormattedDate date={post.data.pubDate} />
							</p>
							<h3>{post.data.title}</h3>
							<p class="card-desc">{post.data.description}</p>
						</div>
					</a>
					<div class="card-footer">
						<TagList tags={post.data.tags} />
					</div>
				</article>
			))}
		</div>
	</section>

	{latestPosts.length > 0 && (
		<section aria-labelledby="latest-title">
			<div class="section-heading">
				<h2 id="latest-title">최신 업데이트</h2>
				<p>릴리즈 분석, 트렌드 정리, 운영 메모를 최신순으로 모았습니다.</p>
			</div>
			<div class="list-grid">
				{latestPosts.map((post, i) => (
					<article class="card compact-card" style={`animation-delay: ${i * 60}ms`}>
						<a href={getPostUrl(post)}>
							<div class="card-body">
								<p class="meta">
									<FormattedDate date={post.data.pubDate} />
								</p>
								<h3>{post.data.title}</h3>
								<p class="card-desc">{post.data.description}</p>
							</div>
						</a>
						<div class="card-footer">
							<TagList tags={post.data.tags} />
						</div>
					</article>
				))}
			</div>
		</section>
	)}
</PageLayout>

<style>
	/* === Hero === */
	.hero {
		position: relative;
		padding: 2.5rem 2rem;
		border-radius: 24px;
		background: rgba(255, 255, 255, 0.7);
		border: 1px solid rgba(255, 255, 255, 0.8);
		box-shadow: var(--shadow);
		backdrop-filter: blur(16px);
		-webkit-backdrop-filter: blur(16px);
		overflow: hidden;
	}

	.hero-glow {
		position: absolute;
		top: -60%;
		right: -20%;
		width: 500px;
		height: 500px;
		border-radius: 50%;
		background: radial-gradient(circle, rgba(99, 102, 241, 0.1) 0%, transparent 70%);
		pointer-events: none;
	}

	.hero-content {
		position: relative;
		display: grid;
		grid-template-columns: minmax(0, 1.2fr) minmax(280px, 0.8fr);
		gap: 2.5rem;
		align-items: start;
	}

	.hero-copy {
		display: grid;
		gap: 1.2rem;
	}

	.badge {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.4rem 0.85rem;
		border-radius: 999px;
		background: rgba(99, 102, 241, 0.08);
		border: 1px solid rgba(99, 102, 241, 0.15);
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		color: var(--accent);
		width: fit-content;
	}

	.badge-dot {
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: var(--accent);
		animation: pulse 2s ease-in-out infinite;
	}

	@keyframes pulse {
		0%, 100% { opacity: 1; }
		50% { opacity: 0.4; }
	}

	.hero h1 {
		max-width: 16ch;
		margin: 0;
		font-size: clamp(2.4rem, 4.5vw, 3.8rem);
		line-height: 1.08;
		letter-spacing: -0.035em;
	}

	.lead {
		max-width: 58ch;
		margin: 0;
		font-size: 1.05rem;
		color: rgb(var(--gray));
		line-height: 1.65;
	}

	.hero-actions {
		display: flex;
		gap: 0.65rem;
		flex-wrap: wrap;
		padding-top: 0.25rem;
	}

	/* === Buttons === */
	.btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.45rem;
		padding: 0.72rem 1.25rem;
		border-radius: 10px;
		text-decoration: none;
		font-weight: 700;
		font-size: 0.92rem;
		transition: all var(--transition-fast);
	}

	.btn-primary {
		background: var(--accent);
		color: #fff;
		box-shadow: 0 2px 8px rgba(99, 102, 241, 0.25);
	}

	.btn-primary:hover {
		background: var(--accent-dark);
		box-shadow: 0 4px 16px rgba(99, 102, 241, 0.3);
		transform: translateY(-1px);
		color: #fff;
	}

	.btn-ghost {
		background: rgba(var(--gray-light), 0.4);
		border: 1px solid rgba(var(--line), 0.6);
		color: rgb(var(--gray-dark));
	}

	.btn-ghost:hover {
		background: rgba(var(--gray-light), 0.7);
		color: rgb(var(--black));
	}

	/* === Hero panel === */
	.hero-panel {
		padding: 1.5rem;
		border-radius: 18px;
		background: rgba(var(--surface-soft), 0.6);
		border: 1px solid rgba(var(--line), 0.4);
	}

	.panel-label {
		margin: 0 0 1rem;
		font-size: 0.7rem;
		font-weight: 700;
		letter-spacing: 0.14em;
		color: rgb(var(--gray));
	}

	.hero-stats {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.75rem;
		margin-bottom: 1.15rem;
	}

	.stat-card {
		padding: 0.85rem;
		border-radius: 12px;
		background: rgba(255, 255, 255, 0.75);
		border: 1px solid rgba(var(--line), 0.35);
	}

	.stat-label {
		display: block;
		font-size: 0.78rem;
		color: rgb(var(--gray));
		margin-bottom: 0.3rem;
	}

	.stat-card strong {
		display: block;
		line-height: 1.3;
		color: rgb(var(--black));
		font-size: 0.92rem;
	}

	.hero-panel ul {
		margin: 0;
		padding-left: 1.15rem;
		color: rgb(var(--gray-dark));
		font-size: 0.92rem;
		line-height: 1.65;
	}

	.hero-panel li {
		margin: 0.3rem 0;
	}

	/* === Section heading === */
	.section-heading {
		margin-bottom: 1.25rem;
	}

	.section-heading h2 {
		margin-bottom: 0.3rem;
	}

	.section-heading p {
		margin: 0;
		color: rgb(var(--gray));
		font-size: 0.95rem;
	}

	.topic-strip,
	.featured,
	section[aria-labelledby='latest-title'] {
		margin-top: 3rem;
	}

	/* === Cards === */
	.featured-grid,
	.list-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1.15rem;
	}

	.card {
		display: flex;
		flex-direction: column;
		border: 1px solid rgba(var(--line), 0.35);
		border-radius: 16px;
		background: rgba(255, 255, 255, 0.8);
		box-shadow: var(--shadow);
		backdrop-filter: blur(10px);
		-webkit-backdrop-filter: blur(10px);
		overflow: hidden;
		transition: box-shadow var(--transition-normal), transform var(--transition-normal), border-color var(--transition-normal);
		animation: fadeInUp 0.5s var(--ease-out) both;
	}

	.card:hover {
		box-shadow: var(--shadow-lg);
		transform: translateY(-3px);
		border-color: rgba(99, 102, 241, 0.2);
	}

	.card a {
		text-decoration: none;
		color: inherit;
	}

	.card-image {
		overflow: hidden;
	}

	.card-image img {
		width: 100%;
		height: auto;
		border-radius: 0;
		transition: transform 0.5s var(--ease-out);
	}

	.card:hover .card-image img {
		transform: scale(1.03);
	}

	.card-body {
		padding: 1.1rem 1.15rem 0.5rem;
	}

	.card h3 {
		margin: 0.25rem 0 0.4rem;
		font-size: 1.1rem;
		line-height: 1.35;
		transition: color var(--transition-fast);
	}

	.card:hover h3 {
		color: var(--accent);
	}

	.card-desc {
		margin: 0;
		font-size: 0.92rem;
		color: rgb(var(--gray));
		line-height: 1.55;
	}

	.card-footer {
		padding: 0.65rem 1.15rem 1rem;
		margin-top: auto;
	}

	.meta {
		font-size: 0.85rem;
		color: rgb(var(--gray));
	}

	@media (max-width: 900px) {
		.hero-content {
			grid-template-columns: 1fr;
		}

		.hero {
			padding: 1.5rem;
		}

		.featured-grid,
		.list-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
