---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';
import TagList from '../components/TagList.astro';
import {
	GITHUB_REPO_URL,
	SITE_BRAND_NAME,
	SITE_DESCRIPTION,
	SITE_SECTION_DESCRIPTION,
	SITE_TITLE,
	SITE_URL,
} from '../consts';
import PageLayout from '../layouts/PageLayout.astro';
import { getAllTags, getPostUrl, sortBlogPosts } from '../utils/blog';

const posts = sortBlogPosts(await getCollection('blog'));
const featuredPosts = posts.slice(0, 3);
const latestPosts = posts.slice(3, 9);
const tags = getAllTags(posts).slice(0, 8);

const structuredData = [
	{
		'@context': 'https://schema.org',
		'@type': 'WebSite',
		name: SITE_TITLE,
		description: SITE_DESCRIPTION,
		url: `${SITE_URL}/`,
		inLanguage: 'ko-KR',
	},
	{
		'@context': 'https://schema.org',
		'@type': 'Organization',
		name: SITE_BRAND_NAME,
		url: SITE_URL,
		sameAs: [GITHUB_REPO_URL],
	},
];
---

<PageLayout
	title={SITE_TITLE}
	description={SITE_DESCRIPTION}
	keywords={['OpenClaw', 'AI 에이전트', '자동화', '홈서버', 'SEO']}
	structuredData={structuredData}
>
	<section class="hero card-surface">
		<div class="hero-copy">
			<p class="eyebrow">OPENCLAW · AI AGENTS · AUTOMATION</p>
			<h1>OpenClaw와 AI 에이전트 운영 인사이트를 축적하는 블로그</h1>
			<p class="lead">{SITE_SECTION_DESCRIPTION}</p>
			<div class="hero-links">
				<a class="primary" href="/blog">전체 글 보기</a>
				<a class="secondary" href="/about">블로그 소개</a>
			</div>
		</div>
		<aside class="hero-panel" aria-label="블로그 개요">
			<p class="panel-label">EDITORIAL FOCUS</p>
			<div class="hero-stats">
				<div>
					<span>대표 주제</span>
					<strong>OpenClaw 운영</strong>
				</div>
				<div>
					<span>콘텐츠 형태</span>
					<strong>트렌드 · 설치 · 배포</strong>
				</div>
			</div>
			<ul>
				<li>릴리즈와 생태계 변화를 빠르게 정리합니다.</li>
				<li>실사용 운영 관점에서 설치·배포·자동화를 아카이브합니다.</li>
				<li>검색과 재탐색이 쉬운 구조로 태그/시리즈를 정리합니다.</li>
			</ul>
		</aside>
	</section>

	{tags.length > 0 && (
		<section class="topic-strip" aria-labelledby="topic-strip-title">
			<div class="section-heading">
				<h2 id="topic-strip-title">주요 토픽</h2>
				<p>콘텐츠가 쌓일수록 태그 허브와 시리즈 구조를 함께 정리합니다.</p>
			</div>
			<TagList tags={tags} />
		</section>
	)}

	<section class="featured" aria-labelledby="featured-title">
		<div class="section-heading">
			<h2 id="featured-title">대표 글</h2>
			<p>먼저 읽기 좋은 최근 글과 운영 기록입니다.</p>
		</div>
		<div class="featured-grid">
			{featuredPosts.map((post) => (
				<article class="card featured-card">
					<a href={getPostUrl(post)}>
						{post.data.heroImage && (
							<Image width={720} height={360} src={post.data.heroImage} alt={post.data.title} />
						)}
						<p class="meta">
							<FormattedDate date={post.data.pubDate} />
						</p>
						<h3>{post.data.title}</h3>
						<p>{post.data.description}</p>
					</a>
					<TagList tags={post.data.tags} />
				</article>
			))}
		</div>
	</section>

	{latestPosts.length > 0 && (
		<section aria-labelledby="latest-title">
			<div class="section-heading">
				<h2 id="latest-title">최신 업데이트</h2>
				<p>릴리즈 분석, 트렌드 정리, 운영 메모를 최신순으로 모았습니다.</p>
			</div>
			<div class="list-grid">
				{latestPosts.map((post) => (
					<article class="card compact-card">
						<a href={getPostUrl(post)}>
							<p class="meta">
								<FormattedDate date={post.data.pubDate} />
							</p>
							<h3>{post.data.title}</h3>
							<p>{post.data.description}</p>
						</a>
						<TagList tags={post.data.tags} />
					</article>
				))}
			</div>
		</section>
	)}
</PageLayout>

<style>
	.hero {
		display: grid;
		grid-template-columns: minmax(0, 1.15fr) minmax(280px, 0.85fr);
		gap: 2rem;
		align-items: start;
		padding: 2rem;
		border-radius: 30px;
	}

	.hero-copy {
		display: grid;
		gap: 1rem;
	}

	.eyebrow {
		margin: 0;
		font-size: 0.78rem;
		font-weight: 800;
		letter-spacing: 0.16em;
		color: var(--accent);
	}

	.hero h1 {
		max-width: 12ch;
		margin: 0;
	}

	.lead {
		max-width: 62ch;
		margin: 0;
		font-size: 1.08rem;
		color: rgb(var(--gray-dark));
	}

	.hero-links {
		display: flex;
		gap: 0.8rem;
		flex-wrap: wrap;
	}

	.hero-links a {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.82rem 1rem;
		border-radius: 999px;
		text-decoration: none;
		font-weight: 700;
	}

	.hero-links .primary {
		background: var(--accent);
		color: #fff;
	}

	.hero-links .secondary {
		background: rgba(255, 255, 255, 0.76);
		border: 1px solid rgba(var(--line), 0.8);
		color: rgb(var(--gray-dark));
	}

	.hero-panel {
		padding: 1.35rem;
		border-radius: 24px;
		background: rgba(255, 255, 255, 0.72);
		border: 1px solid rgba(255, 255, 255, 0.9);
	}

	.panel-label {
		margin: 0 0 1rem;
		font-size: 0.74rem;
		font-weight: 800;
		letter-spacing: 0.14em;
		color: rgb(var(--gray));
	}

	.hero-stats {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.9rem;
		margin-bottom: 1rem;
	}

	.hero-stats div {
		padding: 0.95rem;
		border-radius: 18px;
		background: rgba(var(--surface-soft), 0.7);
		border: 1px solid rgba(var(--line), 0.55);
	}

	.hero-stats span {
		display: block;
		font-size: 0.82rem;
		color: rgb(var(--gray));
		margin-bottom: 0.35rem;
	}

	.hero-stats strong {
		display: block;
		line-height: 1.25;
		color: rgb(var(--black));
	}

	.hero-panel ul {
		margin: 0;
		padding-left: 1.1rem;
		color: rgb(var(--gray-dark));
	}

	.section-heading {
		margin-bottom: 1rem;
	}

	.section-heading p {
		margin: 0;
		color: rgb(var(--gray));
	}

	.topic-strip,
	.featured,
	section[aria-labelledby='latest-title'] {
		margin-top: 2.4rem;
	}

	.featured-grid,
	.list-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1.1rem;
	}

	.card {
		display: grid;
		gap: 0.8rem;
		padding: 1.15rem;
		border: 1px solid rgba(255, 255, 255, 0.9);
		border-radius: 24px;
		background: rgba(255, 255, 255, 0.72);
		box-shadow: var(--shadow);
		backdrop-filter: blur(14px);
	}

	.card a {
		text-decoration: none;
		color: inherit;
	}

	.card img {
		width: 100%;
		height: auto;
		border-radius: 14px;
	}

	.card h3 {
		margin: 0.2rem 0 0.4rem;
		font-size: 1.2rem;
	}

	.card p {
		margin: 0;
	}

	.meta {
		font-size: 0.92rem;
		color: rgb(var(--gray));
	}

	@media (max-width: 900px) {
		.hero {
			grid-template-columns: 1fr;
			padding: 1.35rem;
		}

		.featured-grid,
		.list-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
