---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';
import TagList from '../components/TagList.astro';
import {
	GITHUB_REPO_URL,
	SITE_BRAND_NAME,
	SITE_DESCRIPTION,
	SITE_SECTION_DESCRIPTION,
	SITE_TITLE,
	SITE_URL,
} from '../consts';
import PageLayout from '../layouts/PageLayout.astro';
import { getAllTags, getPostUrl, sortBlogPosts } from '../utils/blog';

const posts = sortBlogPosts(await getCollection('blog'));
const featuredPosts = posts.slice(0, 3);
const latestPosts = posts.slice(3, 9);
const tags = getAllTags(posts).slice(0, 8);

const structuredData = [
	{
		'@context': 'https://schema.org',
		'@type': 'WebSite',
		name: SITE_TITLE,
		description: SITE_DESCRIPTION,
		url: `${SITE_URL}/`,
		inLanguage: 'ko-KR',
	},
	{
		'@context': 'https://schema.org',
		'@type': 'Organization',
		name: SITE_BRAND_NAME,
		url: SITE_URL,
		sameAs: [GITHUB_REPO_URL],
	},
];
---

<PageLayout
	title={SITE_TITLE}
	description={SITE_DESCRIPTION}
	keywords={['OpenClaw', 'AI 에이전트', '자동화', '홈서버', 'SEO']}
	structuredData={structuredData}
>
	<!-- Hero -->
	<section class="hero card-surface">
		<div class="hero-copy">
			<p class="eyebrow">OPENCLAW &middot; AI AGENTS &middot; AUTOMATION</p>
			<h1>OpenClaw와 AI 에이전트 운영 인사이트를 축적하는 블로그</h1>
			<p class="lead">{SITE_SECTION_DESCRIPTION}</p>
			<div class="hero-links">
				<a class="btn-primary" href="/blog">전체 글 보기 &rarr;</a>
				<a class="btn-secondary" href="/about">블로그 소개</a>
			</div>
		</div>
		<aside class="hero-panel" aria-label="블로그 개요">
			<p class="panel-label">EDITORIAL FOCUS</p>
			<div class="hero-stats">
				<div class="stat-card">
					<span>대표 주제</span>
					<strong>OpenClaw 운영</strong>
				</div>
				<div class="stat-card">
					<span>콘텐츠 형태</span>
					<strong>트렌드 &middot; 설치 &middot; 배포</strong>
				</div>
			</div>
			<ul>
				<li>릴리즈와 생태계 변화를 빠르게 정리합니다.</li>
				<li>실사용 운영 관점에서 설치&middot;배포&middot;자동화를 아카이브합니다.</li>
				<li>검색과 재탐색이 쉬운 구조로 태그/시리즈를 정리합니다.</li>
			</ul>
		</aside>
	</section>

	<!-- Topic strip -->
	{tags.length > 0 && (
		<section class="topic-strip" aria-labelledby="topic-strip-title">
			<div class="section-heading">
				<h2 id="topic-strip-title">주요 토픽</h2>
				<p>콘텐츠가 쌓일수록 태그 허브와 시리즈 구조를 함께 정리합니다.</p>
			</div>
			<TagList tags={tags} />
		</section>
	)}

	<!-- Featured posts -->
	<section class="featured" aria-labelledby="featured-title">
		<div class="section-heading">
			<h2 id="featured-title">대표 글</h2>
			<p>먼저 읽기 좋은 최근 글과 운영 기록입니다.</p>
		</div>
		<div class="featured-grid">
			{featuredPosts.map((post) => (
				<article class="card">
					<a href={getPostUrl(post)}>
						{post.data.heroImage && (
							<Image width={720} height={360} src={post.data.heroImage} alt={post.data.title} />
						)}
						<p class="meta">
							<FormattedDate date={post.data.pubDate} />
						</p>
						<h3>{post.data.title}</h3>
						<p class="desc">{post.data.description}</p>
					</a>
					<TagList tags={post.data.tags} />
				</article>
			))}
		</div>
	</section>

	<!-- Latest posts -->
	{latestPosts.length > 0 && (
		<section aria-labelledby="latest-title">
			<div class="section-heading">
				<h2 id="latest-title">최신 업데이트</h2>
				<p>릴리즈 분석, 트렌드 정리, 운영 메모를 최신순으로 모았습니다.</p>
			</div>
			<div class="list-grid">
				{latestPosts.map((post) => (
					<article class="card compact-card">
						<a href={getPostUrl(post)}>
							<p class="meta">
								<FormattedDate date={post.data.pubDate} />
							</p>
							<h3>{post.data.title}</h3>
							<p class="desc">{post.data.description}</p>
						</a>
						<TagList tags={post.data.tags} />
					</article>
				))}
			</div>
		</section>
	)}
</PageLayout>

<style>
	/* ── Hero ──────────────────────────────────── */
	.hero {
		display: grid;
		grid-template-columns: minmax(0, 1.15fr) minmax(280px, 0.85fr);
		gap: 2rem;
		align-items: start;
		padding: 2.25rem;
		border-radius: var(--radius-xl, 28px);
	}

	.hero-copy {
		display: grid;
		gap: 1rem;
	}

	.eyebrow {
		margin: 0;
		font-size: 0.74rem;
		font-weight: 800;
		letter-spacing: 0.18em;
		color: var(--accent);
		text-transform: uppercase;
	}

	.hero h1 {
		max-width: 15ch;
		margin: 0;
		font-size: clamp(2.6rem, 4.8vw, 4.2rem);
		line-height: 1.06;
	}

	.lead {
		max-width: 60ch;
		margin: 0;
		font-size: 1.06rem;
		color: rgb(var(--gray-dark));
		line-height: 1.65;
	}

	/* ── Hero buttons ─────────────────────────── */
	.hero-links {
		display: flex;
		gap: 0.75rem;
		flex-wrap: wrap;
		padding-top: 0.25rem;
	}

	.hero-links a {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.75rem 1.25rem;
		border-radius: 10px;
		text-decoration: none;
		font-weight: 700;
		font-size: 0.95rem;
		transition: transform 150ms ease, box-shadow 200ms ease;
	}

	.hero-links a:hover {
		transform: translateY(-1px);
	}

	.btn-primary {
		background: var(--accent);
		color: #fff;
		box-shadow: 0 2px 8px rgba(15, 69, 53, 0.2);
	}

	.btn-primary:hover {
		box-shadow: 0 6px 16px rgba(15, 69, 53, 0.28);
	}

	.btn-secondary {
		background: rgba(255, 255, 255, 0.8);
		border: 1px solid rgba(var(--line), 0.7);
		color: rgb(var(--gray-dark));
	}

	.btn-secondary:hover {
		border-color: rgba(var(--line), 1);
		box-shadow: var(--shadow-sm, 0 1px 3px rgba(0,0,0,0.06));
	}

	/* ── Hero panel ───────────────────────────── */
	.hero-panel {
		padding: 1.35rem;
		border-radius: var(--radius-lg, 22px);
		background: rgba(255, 255, 255, 0.65);
		border: 1px solid rgba(var(--line), 0.25);
	}

	.panel-label {
		margin: 0 0 0.85rem;
		font-size: 0.72rem;
		font-weight: 800;
		letter-spacing: 0.15em;
		color: rgb(var(--gray));
	}

	.hero-stats {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.75rem;
		margin-bottom: 1rem;
	}

	.stat-card {
		padding: 0.85rem;
		border-radius: var(--radius-md, 14px);
		background: rgba(var(--surface-soft), 0.65);
		border: 1px solid rgba(var(--line), 0.35);
	}

	.stat-card span {
		display: block;
		font-size: 0.78rem;
		color: rgb(var(--gray));
		margin-bottom: 0.25rem;
	}

	.stat-card strong {
		display: block;
		line-height: 1.3;
		color: rgb(var(--black));
		font-size: 0.95rem;
	}

	.hero-panel ul {
		margin: 0;
		padding-left: 1.1rem;
		color: rgb(var(--gray-dark));
		font-size: 0.92rem;
		line-height: 1.65;
	}

	.hero-panel li {
		margin-bottom: 0.3rem;
	}

	/* ── Sections ─────────────────────────────── */
	.section-heading {
		margin-bottom: 1.15rem;
	}

	.section-heading h2 {
		font-size: clamp(1.5rem, 3vw, 2rem);
	}

	.section-heading p {
		margin: 0.15rem 0 0;
		color: rgb(var(--gray));
		font-size: 0.95rem;
	}

	.topic-strip,
	.featured,
	section[aria-labelledby='latest-title'] {
		margin-top: 3rem;
	}

	/* ── Card grid ────────────────────────────── */
	.featured-grid,
	.list-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
	}

	.card {
		display: grid;
		gap: 0.65rem;
		padding: 1.15rem;
		border: 1px solid rgba(var(--line), 0.25);
		border-radius: var(--radius-lg, 22px);
		background: rgba(255, 255, 255, 0.7);
		box-shadow: var(--shadow-sm, 0 1px 3px rgba(0,0,0,0.06));
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		transition: box-shadow 200ms ease, transform 200ms ease;
	}

	.card:hover {
		box-shadow: var(--shadow, 0 8px 24px rgba(0,0,0,0.08));
		transform: translateY(-2px);
	}

	.card a {
		text-decoration: none;
		color: inherit;
	}

	.card img {
		width: 100%;
		height: auto;
		border-radius: var(--radius-md, 14px);
	}

	.card h3 {
		margin: 0.15rem 0 0.3rem;
		font-size: 1.15rem;
		line-height: 1.35;
		transition: color 150ms ease;
	}

	.card:hover h3 {
		color: var(--accent);
	}

	.card .desc {
		margin: 0;
		font-size: 0.92rem;
		color: rgb(var(--gray));
		line-height: 1.55;
	}

	.card p {
		margin: 0;
	}

	.meta {
		font-size: 0.88rem;
		color: rgb(var(--gray));
	}

	/* ── Responsive ───────────────────────────── */
	@media (max-width: 900px) {
		.hero {
			grid-template-columns: 1fr;
			padding: 1.5rem;
		}

		.hero h1 {
			max-width: none;
		}

		.featured-grid,
		.list-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
