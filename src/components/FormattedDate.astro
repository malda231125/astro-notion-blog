---
interface Props {
	date: Date;
}

const { date } = Astro.props;
---

<time class="formatted-date" datetime={date.toISOString()}>
	{
		date.toLocaleDateString('en-us', {
			year: 'numeric',
			month: 'short',
			day: 'numeric',
		})
	}
</time>

<style>
	.formatted-date {
		color: rgb(var(--gray));
		font-size: 0.88rem;
		font-weight: 500;
		letter-spacing: 0.01em;
	}
</style>
