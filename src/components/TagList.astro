---
import { getTagUrl } from '../utils/blog';

interface Props {
	tags?: string[];
}

const { tags = [] } = Astro.props;
---

{
	tags.length > 0 && (
		<ul class="tag-list" aria-label="태그 목록">
			{tags.map((tag) => (
				<li>
					<a href={getTagUrl(tag)}>#{tag}</a>
				</li>
			))}
		</ul>
	)
}

<style>
	.tag-list {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.tag-list li {
		margin: 0;
	}

	.tag-list a {
		display: inline-flex;
		align-items: center;
		padding: 0.25rem 0.6rem;
		border-radius: 6px;
		background: rgba(var(--gray-light), 0.45);
		color: rgb(var(--gray));
		text-decoration: none;
		font-size: 0.82rem;
		font-weight: 500;
		transition: var(--transition-fast);
	}

	.tag-list a:hover {
		background: rgba(var(--gray-light), 0.75);
		color: rgb(var(--black));
	}
</style>
