---
import { getTagUrl } from '../utils/blog';

interface Props {
	tags?: string[];
}

const { tags = [] } = Astro.props;
---

{
	tags.length > 0 && (
		<ul class="tag-list" aria-label="태그 목록">
			{tags.map((tag) => (
				<li>
					<a href={getTagUrl(tag)}>#{tag}</a>
				</li>
			))}
		</ul>
	)
}

<style>
	.tag-list {
		display: flex;
		flex-wrap: wrap;
		gap: 0.55rem;
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.tag-list li {
		margin: 0;
	}

	.tag-list a {
		display: inline-flex;
		align-items: center;
		padding: 0.35rem 0.7rem;
		border-radius: 999px;
		background: rgba(var(--gray-light), 0.8);
		color: rgb(var(--gray-dark));
		text-decoration: none;
		font-size: 0.92rem;
		font-weight: 600;
		transition: background var(--transition-fast), color var(--transition-fast), transform var(--transition-fast), box-shadow var(--transition-fast);
	}

	.tag-list a:hover {
		background: rgba(28, 79, 65, 0.1);
		color: var(--accent-dark);
		transform: translateY(-1px);
		box-shadow: 0 2px 6px rgba(28, 79, 65, 0.1);
	}

	.tag-list a:focus-visible {
		outline: 2px solid var(--accent);
		outline-offset: 2px;
	}
</style>
