---
import { getTagUrl } from '../utils/blog';

interface Props {
	tags?: string[];
}

const { tags = [] } = Astro.props;
---

{
	tags.length > 0 && (
		<ul class="tag-list" aria-label="태그 목록">
			{tags.map((tag) => (
				<li>
					<a href={getTagUrl(tag)}>#{tag}</a>
				</li>
			))}
		</ul>
	)
}

<style>
	.tag-list {
		display: flex;
		flex-wrap: wrap;
		gap: 0.45rem;
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.tag-list li {
		margin: 0;
	}

	.tag-list a {
		display: inline-flex;
		align-items: center;
		padding: 0.3rem 0.65rem;
		border-radius: 4px;
		background: rgba(var(--gray-light), 0.6);
		border: 1px solid rgba(var(--line), 0.35);
		color: rgb(var(--gray));
		text-decoration: none;
		font-size: 0.82rem;
		font-weight: 500;
		letter-spacing: 0.01em;
		transition: all 0.2s ease;
	}

	.tag-list a:hover {
		background: rgba(200, 69, 62, 0.12);
		border-color: rgba(200, 69, 62, 0.3);
		color: var(--accent);
	}
</style>
