---
import { getTagUrl } from '../utils/blog';

interface Props {
	tags?: string[];
}

const { tags = [] } = Astro.props;
---

{
	tags.length > 0 && (
		<ul class="tag-list" aria-label="태그 목록">
			{tags.map((tag) => (
				<li>
					<a href={getTagUrl(tag)}>#{tag}</a>
				</li>
			))}
		</ul>
	)
}

<style>
	.tag-list {
		display: flex;
		flex-wrap: wrap;
		gap: 0.45rem;
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.tag-list li {
		margin: 0;
	}

	.tag-list a {
		display: inline-flex;
		align-items: center;
		padding: 0.3rem 0.65rem;
		border-radius: 999px;
		background: rgba(var(--gray-light), 0.65);
		color: rgb(var(--gray-dark));
		text-decoration: none;
		font-size: 0.85rem;
		font-weight: 600;
		letter-spacing: -0.01em;
		transition: background 200ms ease, color 200ms ease, transform 150ms ease;
	}

	.tag-list a:hover {
		background: var(--accent-light, rgba(var(--gray-light), 1));
		color: var(--accent);
		transform: translateY(-1px);
	}
</style>
