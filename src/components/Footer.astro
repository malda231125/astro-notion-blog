---
import { GITHUB_REPO_URL, SITE_BRAND_NAME, SITE_DESCRIPTION } from '../consts';
const today = new Date();
---

<footer>
	<div class="footer-inner">
		<div class="footer-accent-line"></div>
		<p class="brand">{SITE_BRAND_NAME}</p>
		<p class="description">{SITE_DESCRIPTION}</p>
		<div class="links">
			<a href="/blog">블로그</a>
			<span class="divider">/</span>
			<a href="/tags">태그</a>
			<span class="divider">/</span>
			<a href="/about">소개</a>
			<span class="divider">/</span>
			<a href="/rss.xml">RSS</a>
			<span class="divider">/</span>
			<a href={GITHUB_REPO_URL} target="_blank" rel="noopener noreferrer">GitHub</a>
		</div>
		<p class="copyright">&copy; {today.getFullYear()} {SITE_BRAND_NAME}. All rights reserved.</p>
	</div>
</footer>

<style>
	footer {
		padding: 3.5rem 1rem 4rem;
		background: rgb(16, 15, 13);
		color: rgb(var(--gray));
		border-top: 1px solid rgba(var(--line), 0.3);
		position: relative;
	}

	.footer-inner {
		max-width: 760px;
		margin: 0 auto;
		text-align: center;
	}

	.footer-accent-line {
		width: 3rem;
		height: 2px;
		background: var(--accent);
		margin: 0 auto 2rem;
		animation: accentLine 0.8s ease both;
	}

	.brand {
		margin: 0 0 0.4rem;
		color: rgb(var(--black));
		font-weight: 700;
		font-family: "Playfair Display", Georgia, serif;
		font-size: 1.15rem;
		letter-spacing: -0.01em;
	}

	.description {
		margin: 0 auto 1.5rem;
		max-width: 640px;
		font-size: 0.92rem;
		line-height: 1.6;
	}

	.links {
		display: flex;
		justify-content: center;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.55rem;
		margin-bottom: 1.5rem;
	}

	.links a {
		text-decoration: none;
		color: rgb(var(--gray));
		font-weight: 500;
		font-size: 0.88rem;
		letter-spacing: 0.02em;
		transition: color 0.2s ease;
	}

	.links a:hover {
		color: var(--accent);
	}

	.divider {
		color: rgba(var(--gray), 0.3);
		font-size: 0.8rem;
	}

	.copyright {
		margin: 0;
		font-size: 0.82rem;
		opacity: 0.5;
		letter-spacing: 0.01em;
	}
</style>
