---
import { GITHUB_REPO_URL, SITE_BRAND_NAME, SITE_DESCRIPTION } from '../consts';
const today = new Date();
---

<footer>
	<div class="footer-inner">
		<div class="footer-top">
			<div class="footer-brand">
				<p class="brand-name">{SITE_BRAND_NAME}</p>
				<p class="description">{SITE_DESCRIPTION}</p>
			</div>
			<nav class="footer-nav" aria-label="하단 내비게이션">
				<div class="nav-col">
					<p class="nav-heading">콘텐츠</p>
					<a href="/blog">블로그</a>
					<a href="/tags">태그</a>
					<a href="/about">소개</a>
				</div>
				<div class="nav-col">
					<p class="nav-heading">링크</p>
					<a href="/rss.xml">RSS 피드</a>
					<a href={GITHUB_REPO_URL} target="_blank" rel="noopener noreferrer">GitHub</a>
				</div>
			</nav>
		</div>
		<div class="footer-bottom">
			<p class="copyright">&copy; {today.getFullYear()} {SITE_BRAND_NAME}. All rights reserved.</p>
		</div>
	</div>
</footer>

<style>
	footer {
		margin-top: var(--space-3xl);
		padding: var(--space-2xl) var(--space-md) var(--space-xl);
		background: rgb(var(--surface-soft));
		border-top: 1px solid rgba(var(--line), 0.5);
	}

	.footer-inner {
		max-width: var(--content-max);
		margin: 0 auto;
	}

	.footer-top {
		display: grid;
		grid-template-columns: 1.2fr 1fr;
		gap: var(--space-xl);
		padding-bottom: var(--space-xl);
	}

	.footer-brand {
		max-width: 420px;
	}

	.brand-name {
		margin: 0 0 0.5rem;
		color: rgb(var(--black));
		font-weight: 800;
		font-size: 1.05rem;
	}

	.description {
		margin: 0;
		color: rgb(var(--gray));
		font-size: 0.95rem;
		line-height: 1.65;
	}

	.footer-nav {
		display: flex;
		gap: var(--space-2xl);
	}

	.nav-col {
		display: flex;
		flex-direction: column;
		gap: 0.45rem;
	}

	.nav-heading {
		margin: 0 0 0.25rem;
		font-size: 0.78rem;
		font-weight: 800;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: rgb(var(--gray));
	}

	.nav-col a {
		text-decoration: none;
		color: rgb(var(--gray-dark));
		font-weight: 500;
		font-size: 0.95rem;
		transition: color var(--duration-fast) var(--ease-out);
	}

	.nav-col a:hover {
		color: var(--accent);
	}

	.footer-bottom {
		padding-top: var(--space-lg);
		border-top: 1px solid rgba(var(--line), 0.4);
	}

	.copyright {
		margin: 0;
		font-size: 0.88rem;
		color: rgb(var(--gray));
	}

	@media (max-width: 640px) {
		.footer-top {
			grid-template-columns: 1fr;
			gap: var(--space-xl);
		}

		.footer-nav {
			gap: var(--space-xl);
		}
	}
</style>
