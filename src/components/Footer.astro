---
import { GITHUB_REPO_URL, SITE_BRAND_NAME, SITE_DESCRIPTION } from '../consts';
const today = new Date();
---

<footer>
	<div class="footer-inner">
		<p class="brand">{SITE_BRAND_NAME}</p>
		<p class="description">{SITE_DESCRIPTION}</p>
		<div class="links">
			<a href="/blog">블로그</a>
			<a href="/tags">태그</a>
			<a href="/about">소개</a>
			<a href="/rss.xml">RSS</a>
			<a href={GITHUB_REPO_URL} target="_blank" rel="noopener noreferrer">GitHub</a>
		</div>
		<p class="copyright">&copy; {today.getFullYear()} {SITE_BRAND_NAME}. All rights reserved.</p>
	</div>
</footer>

<style>
	footer {
		padding: 3rem 1rem 4rem;
		background: var(--color-bg-soft);
		color: var(--color-text-muted);
		border-top: 1px solid var(--color-border-soft);
		transition: background-color 0.3s ease;
	}

	.footer-inner {
		max-width: 760px;
		margin: 0 auto;
		text-align: center;
	}

	.brand {
		margin: 0 0 0.4rem;
		color: var(--color-heading);
		font-weight: 800;
	}

	.description {
		margin: 0 auto 1rem;
		max-width: 640px;
	}

	.links {
		display: flex;
		justify-content: center;
		flex-wrap: wrap;
		gap: 0.9rem;
		margin-bottom: 1rem;
	}

	.links a {
		text-decoration: none;
		color: var(--color-text);
		font-weight: 600;
		transition: color 0.15s ease;
	}

	.links a:hover {
		color: var(--color-primary);
	}

	.copyright {
		margin: 0;
		font-size: 0.95rem;
		color: var(--color-text-subtle);
	}
</style>
