---
import { GITHUB_REPO_URL, SITE_BRAND_NAME, SITE_DESCRIPTION } from '../consts';
const today = new Date();
---

<footer>
	<div class="footer-inner">
		<div class="footer-top">
			<div class="footer-brand">
				<span class="brand-mark">OC</span>
				<div>
					<p class="brand-name">{SITE_BRAND_NAME}</p>
					<p class="description">{SITE_DESCRIPTION}</p>
				</div>
			</div>
			<div class="footer-nav">
				<div class="link-group">
					<p class="link-label">콘텐츠</p>
					<a href="/blog">블로그</a>
					<a href="/tags">태그</a>
					<a href="/about">소개</a>
				</div>
				<div class="link-group">
					<p class="link-label">연결</p>
					<a href="/rss.xml">RSS</a>
					<a href={GITHUB_REPO_URL} target="_blank" rel="noopener noreferrer">GitHub</a>
				</div>
			</div>
		</div>
		<div class="footer-bottom">
			<p class="copyright">&copy; {today.getFullYear()} {SITE_BRAND_NAME}. All rights reserved.</p>
		</div>
	</div>
</footer>

<style>
	footer {
		margin-top: 4rem;
		padding: 3rem 1.25rem 2.5rem;
		background: rgb(var(--surface-soft));
		border-top: 1px solid rgba(var(--line), 0.5);
		color: rgb(var(--gray));
	}

	.footer-inner {
		max-width: 1140px;
		margin: 0 auto;
	}

	.footer-top {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		gap: 3rem;
		padding-bottom: 2rem;
		border-bottom: 1px solid rgba(var(--line), 0.4);
	}

	.footer-brand {
		display: flex;
		align-items: flex-start;
		gap: 0.85rem;
	}

	.brand-mark {
		display: grid;
		place-items: center;
		width: 2.2rem;
		height: 2.2rem;
		border-radius: 10px;
		background: linear-gradient(135deg, var(--accent), var(--accent-dark));
		color: #fff;
		font-weight: 800;
		font-size: 0.72rem;
		letter-spacing: 0.04em;
		flex-shrink: 0;
		margin-top: 0.1rem;
	}

	.brand-name {
		margin: 0 0 0.3rem;
		color: rgb(var(--black));
		font-weight: 800;
		font-size: 1rem;
	}

	.description {
		margin: 0;
		max-width: 380px;
		font-size: 0.92rem;
		line-height: 1.5;
	}

	.footer-nav {
		display: flex;
		gap: 3rem;
		flex-shrink: 0;
	}

	.link-group {
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
	}

	.link-label {
		margin: 0 0 0.2rem;
		font-size: 0.78rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: rgb(var(--gray));
	}

	.link-group a {
		text-decoration: none;
		color: rgb(var(--gray-dark));
		font-size: 0.92rem;
		font-weight: 500;
		transition: color var(--transition-fast);
	}

	.link-group a:hover {
		color: var(--accent);
	}

	.footer-bottom {
		padding-top: 1.5rem;
		text-align: center;
	}

	.copyright {
		margin: 0;
		font-size: 0.85rem;
	}

	@media (max-width: 720px) {
		.footer-top {
			flex-direction: column;
			gap: 2rem;
		}

		.footer-nav {
			gap: 2rem;
		}
	}
</style>
