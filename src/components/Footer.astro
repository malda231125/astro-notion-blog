---
import { GITHUB_REPO_URL, SITE_BRAND_NAME, SITE_DESCRIPTION } from '../consts';
const today = new Date();
---

<footer>
	<div class="footer-inner">
		<div class="footer-top">
			<div class="footer-brand">
				<p class="brand-name">{SITE_BRAND_NAME}</p>
				<p class="description">{SITE_DESCRIPTION}</p>
			</div>
			<div class="footer-nav">
				<a href="/blog">블로그</a>
				<a href="/tags">태그</a>
				<a href="/about">소개</a>
				<a href="/rss.xml">RSS</a>
				<a href={GITHUB_REPO_URL} target="_blank" rel="noopener noreferrer">GitHub</a>
			</div>
		</div>
		<div class="footer-bottom">
			<p class="copyright">&copy; {today.getFullYear()} {SITE_BRAND_NAME}</p>
		</div>
	</div>
</footer>

<style>
	footer {
		margin-top: 4rem;
		border-top: 1px solid rgba(var(--line), 0.5);
		padding: 2.5rem 1rem 3rem;
		color: rgb(var(--gray));
	}

	.footer-inner {
		max-width: 1100px;
		margin: 0 auto;
	}

	.footer-top {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		gap: 2rem;
		padding-bottom: 1.5rem;
		border-bottom: 1px solid rgba(var(--line), 0.35);
	}

	.footer-brand {
		max-width: 400px;
	}

	.brand-name {
		margin: 0 0 0.35rem;
		color: rgb(var(--black));
		font-weight: 700;
		font-size: 0.95rem;
	}

	.description {
		margin: 0;
		font-size: 0.88rem;
		line-height: 1.55;
		color: rgb(var(--gray));
	}

	.footer-nav {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.footer-nav a {
		text-decoration: none;
		color: rgb(var(--gray-dark));
		font-weight: 500;
		font-size: 0.88rem;
		padding: 0.3rem 0.55rem;
		border-radius: 6px;
		transition: var(--transition-fast);
	}

	.footer-nav a:hover {
		background: rgba(var(--gray-light), 0.5);
		color: rgb(var(--black));
	}

	.footer-bottom {
		padding-top: 1.25rem;
	}

	.copyright {
		margin: 0;
		font-size: 0.82rem;
		color: rgb(var(--gray));
	}

	@media (max-width: 640px) {
		.footer-top {
			flex-direction: column;
			gap: 1.25rem;
		}

		.footer-nav {
			gap: 0.35rem;
		}
	}
</style>
