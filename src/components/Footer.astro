---
import { GITHUB_REPO_URL, SITE_BRAND_NAME, SITE_DESCRIPTION } from '../consts';
import Icon from './Icon.astro';
const today = new Date();
---

<footer>
	<div class="footer-inner">
		<p class="brand">{SITE_BRAND_NAME}</p>
		<p class="description">{SITE_DESCRIPTION}</p>
		<div class="links">
			<a href="/blog"><Icon name="book-open" size="1em" /> 블로그</a>
			<a href="/tags"><Icon name="tag" size="1em" /> 태그</a>
			<a href="/about"><Icon name="user" size="1em" /> 소개</a>
			<a href="/rss.xml"><Icon name="rss" size="1em" /> RSS</a>
			<a href={GITHUB_REPO_URL} target="_blank" rel="noopener noreferrer">
				<Icon name="github" size="1em" /> GitHub
			</a>
		</div>
		<p class="copyright">&copy; {today.getFullYear()} {SITE_BRAND_NAME}. All rights reserved.</p>
	</div>
</footer>

<style>
	footer {
		padding: 3rem 1rem 4rem;
		background: linear-gradient(var(--gray-gradient)) no-repeat;
		color: rgb(var(--gray));
	}

	.footer-inner {
		max-width: 760px;
		margin: 0 auto;
		text-align: center;
	}

	.brand {
		margin: 0 0 0.4rem;
		color: rgb(var(--black));
		font-weight: 800;
	}

	.description {
		margin: 0 auto 1rem;
		max-width: 640px;
	}

	.links {
		display: flex;
		justify-content: center;
		flex-wrap: wrap;
		gap: 0.9rem;
		margin-bottom: 1rem;
	}

	.links a {
		display: inline-flex;
		align-items: center;
		gap: 0.3rem;
		text-decoration: none;
		color: rgb(var(--gray-dark));
		font-weight: 600;
		transition: color 0.15s ease;
	}

	.links a:hover {
		color: var(--accent);
	}

	.copyright {
		margin: 0;
		font-size: 0.95rem;
	}
</style>
