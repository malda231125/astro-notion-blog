---
import { GITHUB_REPO_URL, SITE_BRAND_NAME, SITE_DESCRIPTION } from '../consts';
const today = new Date();
---

<footer>
	<div class="footer-inner">
		<div class="footer-top">
			<div class="footer-brand">
				<p class="brand">{SITE_BRAND_NAME}</p>
				<p class="description">{SITE_DESCRIPTION}</p>
			</div>
			<div class="links">
				<a href="/blog">블로그</a>
				<a href="/tags">태그</a>
				<a href="/about">소개</a>
				<a href="/rss.xml">RSS</a>
				<a href={GITHUB_REPO_URL} target="_blank" rel="noopener noreferrer">GitHub</a>
			</div>
		</div>
		<hr />
		<p class="copyright">&copy; {today.getFullYear()} {SITE_BRAND_NAME}. All rights reserved.</p>
	</div>
</footer>

<style>
	footer {
		padding: 3rem 1.25rem 2.5rem;
		background: rgb(var(--surface-soft));
		border-top: 1px solid rgba(var(--line), 0.4);
		color: rgb(var(--gray));
	}

	.footer-inner {
		max-width: 1120px;
		margin: 0 auto;
	}

	.footer-top {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		gap: 2rem;
		flex-wrap: wrap;
	}

	.footer-brand {
		max-width: 420px;
	}

	.brand {
		margin: 0 0 0.4rem;
		color: rgb(var(--black));
		font-weight: 800;
		font-size: 1rem;
	}

	.description {
		margin: 0;
		font-size: 0.92rem;
		line-height: 1.6;
	}

	.links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem 1.2rem;
	}

	.links a {
		text-decoration: none;
		color: rgb(var(--gray-dark));
		font-weight: 600;
		font-size: 0.92rem;
		transition: color 150ms ease;
	}

	.links a:hover {
		color: var(--accent);
	}

	hr {
		border: none;
		border-top: 1px solid rgba(var(--line), 0.45);
		margin: 1.75rem 0 1.25rem;
	}

	.copyright {
		margin: 0;
		font-size: 0.85rem;
		color: rgb(var(--gray));
	}

	@media (max-width: 640px) {
		.footer-top {
			flex-direction: column;
			align-items: center;
			text-align: center;
		}

		.links {
			justify-content: center;
		}

		.copyright {
			text-align: center;
		}
	}
</style>
