---
import { GITHUB_REPO_URL, SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav aria-label="주요 내비게이션">
		<a class="brand" href="/" aria-label={`${SITE_TITLE} 홈`}>
			<span class="brand-mark">OC</span>
			<span class="brand-copy">
				<strong>OpenClaw 인사이트</strong>
				<span>AI 에이전트 운영 아카이브</span>
			</span>
		</a>
		<div class="internal-links">
			<HeaderLink href="/">홈</HeaderLink>
			<HeaderLink href="/blog">블로그</HeaderLink>
			<HeaderLink href="/tags">태그</HeaderLink>
			<HeaderLink href="/about">소개</HeaderLink>
		</div>
		<div class="external-links">
			<a href="/rss.xml" aria-label="RSS 피드">RSS</a>
			<a href={GITHUB_REPO_URL} target="_blank" rel="noopener noreferrer" aria-label="GitHub 저장소">GitHub</a>
		</div>
	</nav>
</header>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: 20;
		padding: 0 1.25rem;
		background: rgba(255, 251, 246, 0.88);
		backdrop-filter: blur(20px);
		-webkit-backdrop-filter: blur(20px);
		border-bottom: 1px solid rgba(var(--line), 0.35);
	}

	nav {
		max-width: 1120px;
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1.25rem;
		padding: 0.8rem 0;
	}

	/* ── Brand ────────────────────────────────── */
	.brand {
		display: inline-flex;
		align-items: center;
		gap: 0.75rem;
		text-decoration: none;
		transition: opacity 150ms ease;
	}

	.brand:hover {
		opacity: 0.8;
	}

	.brand-mark {
		display: grid;
		place-items: center;
		width: 2.35rem;
		height: 2.35rem;
		border-radius: 10px;
		background: linear-gradient(145deg, var(--accent), var(--accent-dark));
		color: #fff;
		font-weight: 800;
		font-size: 0.82rem;
		letter-spacing: 0.05em;
		box-shadow: 0 3px 10px rgba(15, 69, 53, 0.22);
		transition: transform 150ms ease;
	}

	.brand:hover .brand-mark {
		transform: scale(1.05);
	}

	.brand-copy {
		display: grid;
		line-height: 1.15;
	}

	.brand-copy strong {
		color: rgb(var(--black));
		font-size: 0.92rem;
		letter-spacing: -0.01em;
	}

	.brand-copy span {
		color: rgb(var(--gray));
		font-size: 0.78rem;
	}

	/* ── Navigation links ─────────────────────── */
	.internal-links,
	.external-links {
		display: flex;
		align-items: center;
		gap: 0.15rem;
	}

	.internal-links :global(a),
	.external-links a {
		display: inline-flex;
		align-items: center;
		gap: 0.3rem;
		padding: 0.4rem 0.7rem;
		border-radius: 8px;
		color: rgb(var(--gray-dark));
		font-weight: 600;
		font-size: 0.92rem;
		text-decoration: none;
		transition: color 150ms ease, background 150ms ease;
	}

	.internal-links :global(a:hover),
	.external-links a:hover {
		color: var(--accent);
		background: rgba(26, 107, 82, 0.06);
	}

	.external-links {
		gap: 0.25rem;
	}

	.external-links a {
		font-size: 0.88rem;
		color: rgb(var(--gray));
	}

	/* ── Responsive ────────────────────────────── */
	@media (max-width: 860px) {
		nav {
			flex-wrap: wrap;
			justify-content: center;
			gap: 0.5rem;
		}

		.brand {
			width: 100%;
			justify-content: center;
		}
	}

	@media (max-width: 560px) {
		header {
			padding: 0 0.75rem;
		}

		.internal-links,
		.external-links {
			width: 100%;
			justify-content: center;
			flex-wrap: wrap;
			gap: 0.1rem;
		}

		.internal-links :global(a),
		.external-links a {
			padding: 0.35rem 0.5rem;
			font-size: 0.88rem;
		}
	}
</style>
