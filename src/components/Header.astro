---
import { GITHUB_REPO_URL, SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<a class="skip-link" href="#main-content">본문으로 건너뛰기</a>
<header>
	<nav aria-label="주요 내비게이션">
		<a class="brand" href="/" aria-label={`${SITE_TITLE} 홈`}>
			<span class="brand-mark">OC</span>
			<span class="brand-copy">
				<strong>OpenClaw 인사이트</strong>
				<span>AI 에이전트 운영 아카이브</span>
			</span>
		</a>
		<div class="nav-links">
			<div class="internal-links">
				<HeaderLink href="/">홈</HeaderLink>
				<HeaderLink href="/blog">블로그</HeaderLink>
				<HeaderLink href="/tags">태그</HeaderLink>
				<HeaderLink href="/about">소개</HeaderLink>
			</div>
			<div class="divider" aria-hidden="true"></div>
			<div class="external-links">
				<a href="/rss.xml" aria-label="RSS 피드">
					<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/></svg>
					<span>RSS</span>
				</a>
				<a href={GITHUB_REPO_URL} target="_blank" rel="noopener noreferrer" aria-label="GitHub 저장소">
					<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
					<span>GitHub</span>
				</a>
			</div>
		</div>
		<button
			class="mobile-toggle"
			aria-label="메뉴 열기"
			aria-expanded="false"
			aria-controls="mobile-menu"
		>
			<svg class="icon-menu" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
			<svg class="icon-close" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true" style="display:none"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
		</button>
	</nav>
	<div id="mobile-menu" class="mobile-menu" aria-hidden="true">
		<div class="mobile-menu-inner">
			<HeaderLink href="/">홈</HeaderLink>
			<HeaderLink href="/blog">블로그</HeaderLink>
			<HeaderLink href="/tags">태그</HeaderLink>
			<HeaderLink href="/about">소개</HeaderLink>
			<div class="mobile-divider"></div>
			<a href="/rss.xml">RSS</a>
			<a href={GITHUB_REPO_URL} target="_blank" rel="noopener noreferrer">GitHub</a>
		</div>
	</div>
</header>

<script>
	const toggle = document.querySelector('.mobile-toggle');
	const menu = document.getElementById('mobile-menu');
	const iconMenu = toggle?.querySelector('.icon-menu') as HTMLElement | null;
	const iconClose = toggle?.querySelector('.icon-close') as HTMLElement | null;

	toggle?.addEventListener('click', () => {
		const isOpen = toggle.getAttribute('aria-expanded') === 'true';
		toggle.setAttribute('aria-expanded', String(!isOpen));
		toggle.setAttribute('aria-label', isOpen ? '메뉴 열기' : '메뉴 닫기');
		menu?.setAttribute('aria-hidden', String(isOpen));
		menu?.classList.toggle('open', !isOpen);
		if (iconMenu) iconMenu.style.display = isOpen ? '' : 'none';
		if (iconClose) iconClose.style.display = isOpen ? 'none' : '';
	});
</script>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: var(--z-sticky);
		padding: 0 var(--space-md);
		background: rgba(253, 251, 247, 0.85);
		backdrop-filter: blur(20px) saturate(1.2);
		-webkit-backdrop-filter: blur(20px) saturate(1.2);
		border-bottom: 1px solid rgba(var(--line), 0.45);
		transition: box-shadow var(--duration-base) var(--ease-out);
	}

	nav {
		max-width: var(--content-max);
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--space-md);
		padding: 0.85rem 0;
	}

	/* Brand */
	.brand {
		display: inline-flex;
		align-items: center;
		gap: 0.75rem;
		text-decoration: none;
		flex-shrink: 0;
		transition: opacity var(--duration-fast) var(--ease-out);
	}

	.brand:hover {
		opacity: 0.85;
	}

	.brand-mark {
		display: grid;
		place-items: center;
		width: 2.4rem;
		height: 2.4rem;
		border-radius: var(--radius-full);
		background: linear-gradient(135deg, var(--accent), var(--accent-dark));
		color: #fff;
		font-weight: 800;
		font-size: 0.82rem;
		letter-spacing: 0.04em;
		box-shadow: 0 4px 12px rgba(20, 77, 59, 0.2);
		transition: transform var(--duration-base) var(--ease-spring);
	}

	.brand:hover .brand-mark {
		transform: scale(1.05);
	}

	.brand-copy {
		display: grid;
		line-height: 1.1;
	}

	.brand-copy strong {
		color: rgb(var(--black));
		font-size: 0.95rem;
	}

	.brand-copy span {
		color: rgb(var(--gray));
		font-size: 0.8rem;
	}

	/* Nav links */
	.nav-links {
		display: flex;
		align-items: center;
		gap: var(--space-md);
	}

	.internal-links,
	.external-links {
		display: flex;
		align-items: center;
		gap: 0.1rem;
	}

	.internal-links :global(a),
	.external-links a {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		padding: 0.45rem 0.75rem;
		border-radius: var(--radius-sm);
		color: rgb(var(--gray-dark));
		font-weight: 600;
		font-size: 0.92rem;
		text-decoration: none;
		transition: background var(--duration-fast) var(--ease-out),
			color var(--duration-fast) var(--ease-out);
	}

	.internal-links :global(a:hover),
	.external-links a:hover {
		background: rgba(var(--gray-light), 0.5);
		color: rgb(var(--black));
	}

	.internal-links :global(a.active) {
		background: var(--accent-light);
		color: var(--accent);
		font-weight: 700;
	}

	.divider {
		width: 1px;
		height: 20px;
		background: rgba(var(--line), 0.6);
	}

	/* Mobile toggle */
	.mobile-toggle {
		display: none;
		align-items: center;
		justify-content: center;
		width: 44px;
		height: 44px;
		padding: 0;
		border: none;
		border-radius: var(--radius-sm);
		background: transparent;
		color: rgb(var(--gray-dark));
		cursor: pointer;
		transition: background var(--duration-fast) var(--ease-out);
	}

	.mobile-toggle:hover {
		background: rgba(var(--gray-light), 0.5);
	}

	/* Mobile menu */
	.mobile-menu {
		display: none;
		overflow: hidden;
		max-height: 0;
		opacity: 0;
		transition: max-height var(--duration-slow) var(--ease-out),
			opacity var(--duration-base) var(--ease-out);
	}

	.mobile-menu.open {
		max-height: 400px;
		opacity: 1;
	}

	.mobile-menu-inner {
		display: flex;
		flex-direction: column;
		gap: 0.15rem;
		padding: 0.5rem 0 1rem;
		max-width: var(--content-max);
		margin: 0 auto;
	}

	.mobile-menu-inner :global(a),
	.mobile-menu-inner a {
		display: block;
		padding: 0.7rem 0.85rem;
		border-radius: var(--radius-sm);
		color: rgb(var(--gray-dark));
		font-weight: 600;
		font-size: 1rem;
		text-decoration: none;
		transition: background var(--duration-fast) var(--ease-out);
	}

	.mobile-menu-inner :global(a:hover),
	.mobile-menu-inner a:hover {
		background: rgba(var(--gray-light), 0.5);
	}

	.mobile-menu-inner :global(a.active) {
		background: var(--accent-light);
		color: var(--accent);
	}

	.mobile-divider {
		height: 1px;
		background: rgba(var(--line), 0.4);
		margin: 0.5rem 0;
	}

	@media (max-width: 768px) {
		.nav-links {
			display: none;
		}

		.mobile-toggle {
			display: flex;
		}

		.mobile-menu {
			display: block;
			border-top: 1px solid rgba(var(--line), 0.3);
		}
	}

	@media (max-width: 420px) {
		.brand-copy span {
			display: none;
		}
	}
</style>
