---
import { GITHUB_REPO_URL, SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav aria-label="주요 내비게이션">
		<a class="brand" href="/" aria-label={`${SITE_TITLE} 홈`}>
			<span class="brand-mark">OC</span>
			<span class="brand-copy">
				<strong>OpenClaw 인사이트</strong>
				<span>AI 에이전트 운영 아카이브</span>
			</span>
		</a>
		<div class="internal-links">
			<HeaderLink href="/">홈</HeaderLink>
			<HeaderLink href="/blog">블로그</HeaderLink>
			<HeaderLink href="/tags">태그</HeaderLink>
			<HeaderLink href="/about">소개</HeaderLink>
		</div>
		<div class="external-links">
			<a href="/rss.xml">RSS</a>
			<a href={GITHUB_REPO_URL} target="_blank" rel="noopener noreferrer">GitHub</a>
		</div>
	</nav>
</header>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: 20;
		padding: 0 1rem;
		background: rgba(250, 250, 250, 0.85);
		backdrop-filter: blur(20px);
		-webkit-backdrop-filter: blur(20px);
		border-bottom: 1px solid rgba(var(--line), 0.4);
	}

	nav {
		max-width: 1100px;
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		padding: 0.85rem 0;
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 0.75rem;
		text-decoration: none;
		transition: var(--transition-fast);
	}

	.brand:hover {
		opacity: 0.8;
	}

	.brand:active {
		transform: scale(0.98);
	}

	.brand-mark {
		display: grid;
		place-items: center;
		width: 2.25rem;
		height: 2.25rem;
		border-radius: 10px;
		background: var(--accent);
		color: #fff;
		font-weight: 800;
		font-size: 0.75rem;
		letter-spacing: 0.04em;
	}

	.brand-copy {
		display: grid;
		line-height: 1.15;
	}

	.brand-copy strong {
		color: rgb(var(--black));
		font-size: 0.92rem;
		font-weight: 700;
	}

	.brand-copy span {
		color: rgb(var(--gray));
		font-size: 0.78rem;
	}

	.internal-links,
	.external-links {
		display: flex;
		align-items: center;
		gap: 0.25rem;
	}

	.internal-links :global(a),
	.external-links a {
		color: rgb(var(--gray-dark));
		font-weight: 500;
		font-size: 0.9rem;
		text-decoration: none;
		padding: 0.4rem 0.65rem;
		border-radius: 8px;
		transition: var(--transition-fast);
	}

	.internal-links :global(a):hover,
	.external-links a:hover {
		background: rgba(var(--gray-light), 0.5);
		color: rgb(var(--black));
	}

	.internal-links :global(a):active,
	.external-links a:active {
		transform: translateY(1px) scale(0.98);
	}

	.external-links a {
		font-size: 0.85rem;
		color: rgb(var(--gray));
	}

	@media (max-width: 860px) {
		nav {
			flex-wrap: wrap;
			justify-content: center;
		}

		.brand {
			width: 100%;
			justify-content: center;
		}
	}

	@media (max-width: 560px) {
		.internal-links,
		.external-links {
			width: 100%;
			justify-content: center;
			flex-wrap: wrap;
		}
	}
</style>
