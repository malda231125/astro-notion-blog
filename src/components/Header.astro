---
import { GITHUB_REPO_URL, SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav aria-label="주요 내비게이션">
		<a class="brand" href="/" aria-label={`${SITE_TITLE} 홈`}>
			<span class="brand-mark">OC</span>
			<span class="brand-copy">
				<strong>OpenClaw 인사이트</strong>
				<span>AI 에이전트 운영 아카이브</span>
			</span>
		</a>
		<div class="internal-links">
			<HeaderLink href="/">홈</HeaderLink>
			<HeaderLink href="/blog">블로그</HeaderLink>
			<HeaderLink href="/tags">태그</HeaderLink>
			<HeaderLink href="/about">소개</HeaderLink>
		</div>
		<div class="external-links">
			<a href="/rss.xml">RSS</a>
			<a href={GITHUB_REPO_URL} target="_blank" rel="noopener noreferrer">GitHub</a>
		</div>
	</nav>
</header>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: 20;
		padding: 0 1rem;
		background: rgba(22, 21, 19, 0.88);
		backdrop-filter: blur(20px) saturate(1.2);
		border-bottom: 1px solid rgba(var(--line), 0.35);
		animation: fadeIn 0.6s ease both;
	}

	nav {
		max-width: 1120px;
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		padding: 0.95rem 0;
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 0.85rem;
		text-decoration: none;
		transition: opacity 0.2s ease;
	}

	.brand:hover {
		opacity: 0.85;
	}

	.brand-mark {
		display: grid;
		place-items: center;
		width: 2.5rem;
		height: 2.5rem;
		border-radius: 10px;
		background: var(--accent);
		color: #fff;
		font-weight: 800;
		font-size: 0.82rem;
		letter-spacing: 0.06em;
		box-shadow: 0 4px 16px rgba(200, 69, 62, 0.3);
		transition: transform 0.25s ease, box-shadow 0.25s ease;
	}

	.brand:hover .brand-mark {
		transform: scale(1.05);
		box-shadow: 0 6px 20px rgba(200, 69, 62, 0.4);
	}

	.brand-copy {
		display: grid;
		line-height: 1.08;
	}

	.brand-copy strong {
		color: rgb(var(--black));
		font-size: 0.98rem;
	}

	.brand-copy span {
		color: rgb(var(--gray));
		font-size: 0.82rem;
	}

	.internal-links,
	.external-links {
		display: flex;
		align-items: center;
		gap: 1rem;
	}

	.internal-links :global(a),
	.external-links a {
		color: rgb(var(--gray));
		font-weight: 500;
		text-decoration: none;
		font-size: 0.92rem;
		letter-spacing: 0.02em;
		transition: color 0.2s ease;
		position: relative;
	}

	.internal-links :global(a):hover,
	.external-links a:hover {
		color: rgb(var(--black));
	}

	.internal-links :global(a)::after {
		content: "";
		position: absolute;
		bottom: -4px;
		left: 0;
		width: 0;
		height: 1px;
		background: var(--accent);
		transition: width 0.3s ease;
	}

	.internal-links :global(a):hover::after,
	.internal-links :global(a.active)::after {
		width: 100%;
	}

	.internal-links :global(a.active) {
		color: rgb(var(--black));
		font-weight: 700;
		text-decoration: none;
	}

	.external-links a {
		font-size: 0.88rem;
		opacity: 0.65;
	}

	.external-links a:hover {
		opacity: 1;
	}

	@media (max-width: 860px) {
		nav {
			flex-wrap: wrap;
			justify-content: center;
		}

		.brand {
			width: 100%;
			justify-content: center;
		}
	}

	@media (max-width: 560px) {
		.internal-links,
		.external-links {
			width: 100%;
			justify-content: center;
			flex-wrap: wrap;
		}
	}
</style>
