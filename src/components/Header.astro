---
import { GITHUB_REPO_URL, SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav aria-label="주요 내비게이션">
		<div class="brand">
			<a href="/">{SITE_TITLE}</a>
		</div>
		<div class="internal-links">
			<HeaderLink href="/">홈</HeaderLink>
			<HeaderLink href="/blog">블로그</HeaderLink>
			<HeaderLink href="/tags">태그</HeaderLink>
			<HeaderLink href="/about">소개</HeaderLink>
		</div>
		<div class="external-links">
			<a href="/rss.xml">RSS</a>
			<a href={GITHUB_REPO_URL} target="_blank" rel="noopener noreferrer">GitHub</a>
		</div>
	</nav>
</header>

<style>
	header {
		margin: 0;
		padding: 0 1rem;
		background: rgba(255, 255, 255, 0.85);
		backdrop-filter: blur(10px);
		border-bottom: 1px solid rgba(var(--gray-light), 0.95);
	}

	nav {
		max-width: 1120px;
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		padding: 0.95rem 0;
	}

	.brand a {
		font-size: 1.05rem;
		font-weight: 800;
		color: rgb(var(--black));
		text-decoration: none;
	}

	.internal-links,
	.external-links {
		display: flex;
		align-items: center;
		gap: 0.95rem;
	}

	.internal-links a,
	.external-links a {
		color: rgb(var(--gray-dark));
		font-weight: 600;
		text-decoration: none;
	}

	.external-links a {
		font-size: 0.95rem;
	}

	@media (max-width: 860px) {
		nav {
			flex-wrap: wrap;
			justify-content: center;
		}

		.brand {
			width: 100%;
			text-align: center;
		}
	}

	@media (max-width: 560px) {
		.internal-links,
		.external-links {
			width: 100%;
			justify-content: center;
			flex-wrap: wrap;
		}
	}
</style>
