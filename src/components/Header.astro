---
import { GITHUB_REPO_URL, SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav aria-label="주요 내비게이션">
		<a class="brand" href="/" aria-label={`${SITE_TITLE} 홈`}>
			<span class="brand-mark">OC</span>
			<span class="brand-copy">
				<strong>OpenClaw 인사이트</strong>
				<span>AI 에이전트 운영 아카이브</span>
			</span>
		</a>
		<div class="internal-links">
			<HeaderLink href="/">홈</HeaderLink>
			<HeaderLink href="/blog">블로그</HeaderLink>
			<HeaderLink href="/tags">태그</HeaderLink>
			<HeaderLink href="/about">소개</HeaderLink>
		</div>
		<div class="external-links">
			<a href="/rss.xml">RSS</a>
			<a href={GITHUB_REPO_URL} target="_blank" rel="noopener noreferrer">GitHub</a>
		</div>
	</nav>
</header>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: 20;
		padding: 0 1rem;
		background: rgba(255, 252, 247, 0.82);
		backdrop-filter: blur(18px);
		border-bottom: 1px solid rgba(var(--line), 0.55);
	}

	nav {
		max-width: 1120px;
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		padding: 0.95rem 0;
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 0.85rem;
		text-decoration: none;
	}

	.brand-mark {
		display: grid;
		place-items: center;
		width: 2.5rem;
		height: 2.5rem;
		border-radius: 999px;
		background: linear-gradient(135deg, var(--accent), var(--accent-dark));
		color: #fff;
		font-weight: 800;
		letter-spacing: 0.04em;
		box-shadow: 0 12px 24px rgba(18, 53, 44, 0.16);
	}

	.brand-copy {
		display: grid;
		line-height: 1.08;
	}

	.brand-copy strong {
		color: rgb(var(--black));
		font-size: 0.98rem;
	}

	.brand-copy span {
		color: rgb(var(--gray));
		font-size: 0.88rem;
	}

	.internal-links,
	.external-links {
		display: flex;
		align-items: center;
		gap: 1rem;
	}

	.internal-links :global(a),
	.external-links a {
		color: rgb(var(--gray-dark));
		font-weight: 600;
		text-decoration: none;
		transition: color 0.15s ease;
	}

	.internal-links :global(a:hover),
	.external-links a:hover {
		color: var(--accent);
	}

	.internal-links :global(a:focus-visible),
	.external-links a:focus-visible {
		outline: none;
		box-shadow: var(--focus-ring);
		border-radius: 4px;
	}

	.brand:focus-visible {
		outline: none;
		box-shadow: var(--focus-ring);
		border-radius: 8px;
	}

	.external-links a {
		font-size: 0.95rem;
	}

	@media (max-width: 860px) {
		nav {
			flex-wrap: wrap;
			justify-content: center;
		}

		.brand {
			width: 100%;
			justify-content: center;
		}
	}

	@media (max-width: 560px) {
		.internal-links,
		.external-links {
			width: 100%;
			justify-content: center;
			flex-wrap: wrap;
		}
	}
</style>
